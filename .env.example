# ──────────────────────────────────────────────────────────────────────
# SIGNAL SYSTEM — Environment Configuration Reference
# Copy to .env and fill in your values.
# Lines starting with # are comments; uncomment to override defaults.
#
# Conventions used in this file:
#   0=disabled, 1=enabled  (for integer boolean toggles)
#   true/false             (for string boolean toggles)
#   Placeholder secrets    → "your_token_here" / "your_key_here"
# ──────────────────────────────────────────────────────────────────────

# ── CLAUDE API ──────────────────────────────────────────────────────────
# Anthropic API key — required for AURUM and VISION components
ANTHROPIC_API_KEY=your_key_here

# Service installer override: force a specific python interpreter for launchd/systemd
# SIGNAL_PYTHON=/absolute/path/to/python


# ── TELEGRAM — CHANNEL READER (Telethon user account) ──────────────────
# Obtain from https://my.telegram.org (App API — not bot credentials)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
# International phone number in E.164 format
TELEGRAM_PHONE=+1234567890

# Comma-separated channel IDs or @usernames to monitor
# Get channel ID by forwarding a message to @userinfobot
TELEGRAM_CHANNELS=-1001234567890,-1009876543210

# Optional priority execution allowlist (titles or chat IDs; comma-separated).
# If unset/empty, all monitored rooms can dispatch in SIGNAL/HYBRID mode.
# Prefer chat IDs to avoid title-rename drift. Both vars are merged.
# SIGNAL_TRADE_ROOMS=-1001234567890,-1009876543210
# ACTIVE_SIGNAL_TRADE_ROOMS=-1001234567890,-1009876543210


# ── TELEGRAM — BOT (HERALD notifications + AURUM replies) ──────────────
# Create the bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Chat ID where HERALD posts alerts (user, group, or channel)
TELEGRAM_CHAT_ID=987654321


# ══════════════════════════════════════════════════════════════════════
# MT5 FILE BUS
# These paths must point to the SAME folder FORGE.mq5 uses
# (Terminal → Common → Files). Best practice: symlink repo MT5/ →
# Common/Files (see docs/FORGE_BRIDGE.md). Run `make setup-mt5-link`.
# ══════════════════════════════════════════════════════════════════════
MT5_MARKET_FILE=MT5/market_data.json
MT5_CMD_FILE=MT5/command.json
MT5_CONFIG_FILE=MT5/config.json
MT5_MODE_FILE=MT5/mode_status.json
MT5_BROKER_FILE=MT5/broker_info.json

# Optional mirror: write command.json to a second path (for symlink mismatches).
# Leave blank to disable.
# MT5_CMD_FILE_MIRROR=

# Absolute path to MT5 Terminal Common Files directory.
# Used by `make setup-mt5-link` to create the repo MT5/ symlink.
# MT5_PATH=/Users/YOU/Library/Application Support/net.metaquotes.wine.metatrader5/drive_c/users/user/AppData/Roaming/MetaQuotes/Terminal/Common/Files

# macOS MT5 native app absolute paths (alternative to symlink):
# MT5_CMD_FILE=/Users/YOU/Library/Application Support/MetaQuotes/Terminal/Common/Files/command.json
# MT5_MARKET_FILE=/Users/YOU/Library/Application Support/MetaQuotes/Terminal/Common/Files/market_data.json


# ── FORGE MAGIC NUMBER ──────────────────────────────────────────────────
# Must match the MagicNumber input in ea/FORGE.mq5. Group magic = base + group_id.
# FORGE_MAGIC_NUMBER=202401
# Maximum magic offset allowed (group_id upper bound)
# FORGE_MAGIC_MAX=9999


# ══════════════════════════════════════════════════════════════════════
# TRADINGVIEW MCP (LENS)
# LENS fetches live chart data from TradingView via the MCP server.
# ══════════════════════════════════════════════════════════════════════
# Command to launch the TradingView MCP server (npx or node path)
LENS_MCP_CMD=npx tradingview-mcp-jackson
# Symbol and exchange to monitor
LENS_SYMBOL=XAUUSD
LENS_EXCHANGE=FX_IDC
# Comma-separated timeframes to pull (e.g., 5m,1h)
LENS_TIMEFRAMES=5m,1h
# In-memory snapshot TTL in seconds; keep ≤ BRIDGE_LENS_SEC
LENS_CACHE_SEC=60
# How often (seconds) to refresh TradingView MCP while BRIDGE is in WATCH; 0=disable
LENS_WATCH_REFRESH_SEC=60
# Bollinger Band Width squeeze threshold (dimensionless ratio)
LENS_BBW_SQUEEZE=0.035

# Include TradingView textual brief payload in lens snapshots (true/false)
# LENS_ENABLE_TV_BRIEF=true
# TradingView brief refresh interval in seconds
# LENS_TV_BRIEF_INTERVAL_SEC=1800
# Conflict detection thresholds — LENS vs MT5 data
# LENS_MAX_RSI_DIFF=15.0
# LENS_MAX_PRICE_DIFF=5.0


# ══════════════════════════════════════════════════════════════════════
# TRADING PARAMETERS
# ══════════════════════════════════════════════════════════════════════
# Starting mode on BRIDGE launch: OFF | WATCH | SIGNAL | SCALPER | HYBRID | AUTO_SCALPER
DEFAULT_MODE=SIGNAL
# Restore the previous mode from status.json on BRIDGE restart (true/false)
# RESTORE_MODE_ON_RESTART=true

# ── TP MANAGEMENT ───────────────────────────────────────────────────────
# Percentage of open legs to close at TP1 (integer 0–100)
TP1_CLOSE_PCT=70
# Percentage of remaining legs to close at TP2 (integer 0–100)
TP2_CLOSE_PCT=20
# Move all surviving legs' SL to breakeven after TP1 hit (true/false)
MOVE_BE_ON_TP1=true


# ── SIGNAL MODE ─────────────────────────────────────────────────────────
# Lot size per leg for Telegram signal-sourced entries
# SIGNAL_LOT_SIZE=0.01
# Number of ladder legs per signal group
# SIGNAL_NUM_TRADES=4
# Reject signals older than this many seconds; scalping signals must be fresh
# SIGNAL_EXPIRY_SEC=60


# ══════════════════════════════════════════════════════════════════════
# REGIME ENGINE
# HMM-based market regime classification (TREND_BULL, TREND_BEAR,
# VOLATILE, RANGE). Runs inside python/regime.py every bridge tick.
# ══════════════════════════════════════════════════════════════════════
# Master toggle for regime inference snapshots (true/false)
# REGIME_ENGINE_ENABLED=true

# Rollout mode for entry placement:
#   off    = compute nothing; use legacy endpoint-bias only
#   shadow = compute + log regime policy, but execute legacy ladder
#   active = apply regime-conditioned ladder when confidence + freshness pass
# REGIME_ENTRY_MODE=off

# Minimum HMM posterior confidence required to apply active policy (0.0–1.0)
# REGIME_MIN_CONFIDENCE=0.60

# Snapshot freshness gate in seconds; older snapshots are marked stale
# and blocked in active mode (also governs AEGIS countertrend gate)
# REGIME_STALE_SEC=180

# LENS data staleness ceiling for regime features in seconds
# (separate from REGIME_STALE_SEC; governs feature vector collapse)
# REGIME_LENS_STALE_SEC=300

# Number of HMM hidden states (valid range 2–10; more = finer regimes but needs more data)
# REGIME_HMM_COMPONENTS=3

# How often the HMM model is retrained from fresh feature history (seconds)
# REGIME_RETRAIN_INTERVAL_SEC=3600

# Minimum feature-vector samples before HMM training is attempted
# REGIME_MIN_TRAIN_SAMPLES=120

# How often regime snapshots are persisted to SCRIBE (seconds);
# regime transitions are always emitted immediately regardless of this cadence
# REGIME_LOG_INTERVAL_SEC=30

# Phase B — block counter-trend fades when REGIME_ENTRY_MODE=active
# AEGIS_REGIME_COUNTERTREND_BLOCK=true
# Comma-separated sources to gate (default: SCALPER_SUBPATH_DIRECT only)
# AEGIS_REGIME_COUNTERTREND_SOURCES=SCALPER_SUBPATH_DIRECT
# Minimum regime confidence before blocking a fade (0.0–1.0)
# AEGIS_REGIME_COUNTERTREND_MIN_CONFIDENCE=0.55


# ══════════════════════════════════════════════════════════════════════
# AUTO_SCALPER MODE (AURUM-driven autonomous scalping)
# ══════════════════════════════════════════════════════════════════════
# Lot size per leg for AURUM-generated AUTO_SCALPER groups
# AUTO_SCALPER_LOT_SIZE=0.01
# Number of legs per AUTO_SCALPER group
# AUTO_SCALPER_NUM_TRADES=4
# How often AURUM evaluates market data for a new scalp (seconds)
# AUTO_SCALPER_POLL_INTERVAL=120
# Maximum concurrent AUTO_SCALPER groups at any time
# AUTO_SCALPER_MAX_GROUPS=2


# ══════════════════════════════════════════════════════════════════════
# FORGE SCALPER CONFIG
# Native FORGE scalper running inside MT5 (backtestable via Strategy Tester).
# Config is generated from config/scalper_config.defaults.json +
# FORGE_* vars in .env by `make scalper-env-sync` (auto-run on
# `make forge-compile` / `make forge-refresh` / `make forge-reload`).
# Full pipeline: docs/SCALPER_CONFIG_PIPELINE.md
# ══════════════════════════════════════════════════════════════════════

# Operating mode passed through BRIDGE → MT5 config.json
#   NONE   = scalper disabled
#   BB_BOUNCE    = mean-reversion only
#   BB_BREAKOUT  = trend-following breakout only
#   DUAL   = both strategies active
# FORGE_SCALPER_MODE=NONE


# ── LOT SIZING ──────────────────────────────────────────────────────────
# Lot-sizing precedence:
#   AUTO   = check NativeScalperInputsOverrideLotSizing input in MT5; fallback to config
#   INPUTS = use MT5 Inputs for LEG COUNT (ScalperTrades). 2.7.40: lot value always comes from JSON × ScalperLotFactor.
#   CONFIG = always use config/scalper_config.json lot_sizing values
# FORGE_LOT_SIZING_SOURCE=AUTO
# When AUTO: 0=use config leg count, 1=force MT5 Inputs leg count (0=disabled, 1=enabled)
# FORGE_INPUTS_OVERRIDE_LOT_SIZING=0
# Per-leg ABSOLUTE base lot (single source of truth post-v2.7.40). Everything else is a multiplier on this.
# FORGE_FIXED_LOT=0.02
#
# === GLOBAL LOT SCALER (v2.7.40) ===
# Multiplies fixed_lot at the top of combined_lot_factor chain. Mirror of MT5 input ScalperLotFactor.
# Set this in .env for headless/CI runs; set ScalperLotFactor in MT5 panel for ad-hoc session control.
# MT5 input wins when != 1.0; this env value wins when MT5 input stays at default 1.0.
#
#   1.0 → no override (full size, default)
#   0.5 → half-sizing — risk-off, halve all per-leg lots (fixed_lot=0.25 → effective 0.125)
#   2.0 → double-sizing — size-up validated day (fixed_lot=0.25 → effective 0.50)
#   0.1 → emergency halt-size (e.g. during high-impact news)
#
# Range 0.05..10.0; values outside silently clamped at parse time.
# FORGE_GLOBAL_SCALPER_LOT_FACTOR=1.0
# Dynamic leg count range. FORGE resolves actual count from equity DD, regime,
# trend strength, and setup type. Base midpoint = (min+max)/2.
# ADX-conditional boost (EA): ADX<25 → base-1, ADX>35 → base+2 (see FORGE_ENTRY_CONDITIONS.md).
# FORGE_MIN_NUM_TRADES=2
# FORGE_MAX_NUM_TRADES=6
# Legacy single value — sets both min and max when neither min nor max is in .env
# FORGE_NUM_TRADES=4
#
# XAUUSD SELL hard cap — number of legs allowed for SELL on gold.
# Default was 2 (blocked all multi-leg SELLs). Set to match your max_num_trades ceiling.
# FORGE_GOLD_NATIVE_MAX_SELL_LEGS=8
#
# Cap legs when H1+H4 trend not clearly aligned with direction.
# ADX < 25 path: sets maximum legs when direction is unconfirmed.
# FORGE_NATIVE_LEGS_MAX_WHEN_UNCLEAR=2
#
# ── Staged entry — fire all legs at once or scale in ───────────────────────
# staged_initial_legs: how many legs open on the first wave. Set >= max_num_trades
# to fire all legs simultaneously (scalp mode). Set to 1 for classic scale-in.
# FORGE_STAGED_INITIAL_LEGS=8
# staged_add_interval_sec: seconds between staged leg additions (only relevant when
# staged_initial_legs < total n)
# FORGE_STAGED_ADD_INTERVAL_SEC=25
# staged_add_min_favorable_points: minimum favorable price movement before adding
# next staged leg. 3 pts = within TP1 window at 0.4–0.5×ATR. 35 = wait for large move.
# FORGE_STAGED_ADD_MIN_FAVORABLE_POINTS=3


# ── BB_BOUNCE PARAMETERS ────────────────────────────────────────────────
# Minimum retracement % before considering a bounce entry valid (0–100)
# FORGE_BOUNCE_RECLAIM_PCT=20
# Require a rejection candle (wick > body touching the BB band) before entry (0=disabled, 1=enabled)
# FORGE_BOUNCE_REQUIRE_REJECTION_CANDLE=1
# Minimum bar hold before fast-lock SL is allowed to trigger (seconds, bounce)
# FORGE_FAST_LOCK_MIN_HOLD_SEC_BOUNCE=45
# Minimum SL profit multiple before fast-lock can trail (multiplier of SL distance, e.g. 1.35 = 35% buffer)
# FORGE_FAST_LOCK_BREATH_MULT=1.35
# Minimum price profit in points before fast-lock engages (raw MT5 points, e.g. 12 = $1.20 on XAUUSD)
# FORGE_FAST_LOCK_MIN_PROFIT_POINTS=12
# Minimum TP1 distance as a fraction of M5 ATR (e.g. 0.40 = TP1 must be ≥ 0.4×ATR from entry)
# FORGE_BOUNCE_MIN_TP1_ATR_MULT=0.40
# Minimum TP2 distance as a fraction of M5 ATR
# FORGE_BOUNCE_MIN_TP2_ATR_MULT=0.80
# Maximum ADX allowed for BB_BOUNCE entries (above this = trending, not ranging; block bounce)
# FORGE_BOUNCE_ADX_MAX=40
# Fractional lot multiplier for BB_BOUNCE entries (applied on top of fixed_lot).
# Mean-reversion trades carry higher risk than breakouts — use a smaller position.
# 1.0 = full base lot (default, no reduction). 0.25 = quarter lot (e.g. 0.02 at fixed_lot=0.08).
# Example: G5005 BB_BOUNCE loss was −$175 at 3 legs × 0.08 lot; at 0.25 factor → −$44.
# FORGE_BOUNCE_LOT_FACTOR=0.25
# Require H1 EMA bias to agree with bounce direction (0=disabled, 1=enabled)
# FORGE_BOUNCE_REQUIRE_H1_DIRECTION=1
# H1+M15 bounce bias mode: LEGACY | BALANCED | STRICT (see docs/SCALPER_CONFIG_PIPELINE.md)
# FORGE_BOUNCE_HTF_BIAS=STRICT
# Block bounce entries that would trade against the dominant H1+M15 trend alignment (0=disabled, 1=enabled)
# FORGE_BOUNCE_BLOCK_HTF_TREND_ALIGN=0
# Apply bounce ADX max gate in Strategy Tester runs (0=disabled, 1=enabled)
# FORGE_BOUNCE_RESPECT_ADX_MAX_IN_TESTER=1
# Apply H1 filter gate in Strategy Tester runs (0=disabled, 1=enabled)
# FORGE_BOUNCE_RESPECT_H1_FILTER_IN_TESTER=1
# Require the M5 close bar (bar[0]) to confirm the direction before entry (0=disabled, 1=enabled)
# FORGE_BOUNCE_REQUIRE_BAR0_CONFIRM=1
# Minimum composite candle quality score required for bounce entry (0–3; 0 = any candle accepted)
# FORGE_BOUNCE_MIN_CANDLE_SCORE=1
# Require price to be near a high-volume liquidity zone before bounce entry (0=disabled, 1=enabled)
# FORGE_BOUNCE_REQUIRE_LIQUIDITY_ZONE=1
# SL ATR multiplier for BB_BOUNCE trades (e.g. 1.5 = SL placed 1.5×ATR from entry)
# FORGE_BOUNCE_SL_ATR_MULT=1.5


# ── BB_BREAKOUT PARAMETERS ──────────────────────────────────────────────
# Minimum ADX required for BB_BREAKOUT entry (Wilder standard: 25 = trending)
# FORGE_BREAKOUT_ADX_MIN=16
# Stricter ADX floor for SELL-only breakouts (SELL entries more error-prone at weak ADX than BUYs).
# Separate from FORGE_BREAKOUT_ADX_MIN — lets you require stronger trend confirmation for shorts.
# Default: 25 (EA hard-coded). Raise to 30 to only allow SELLs in confirmed downtrends.
# Gate fired: entry_quality_adx_min_sell
# FORGE_BREAKOUT_ADX_MIN_SELL=25
# Minimum bar hold before fast-lock SL is allowed to trigger (seconds, breakout)
# FORGE_FAST_LOCK_MIN_HOLD_SEC_BREAKOUT=50
# Wait for a candle to retest the breakout level before entering (0=disabled, 1=enabled)
# FORGE_BREAKOUT_USE_RETEST=1
# How many M5 bars back the retest can occur (1–20)
# FORGE_BREAKOUT_RETEST_MAX_BARS=6
# RSI ceiling for BUY breakout entries (block when RSI >= this; avoids overbought chasing)
# FORGE_BREAKOUT_RSI_BUY_CEIL=70
# RSI floor for SELL breakout entries (block when RSI <= this; avoids oversold chasing)
# FORGE_BREAKOUT_RSI_SELL_FLOOR=30
# Block SELL if RSI was rising bar-over-bar (filters weak momentum SELLs); 0=disabled, 1=enabled
# FORGE_BREAKOUT_REQUIRE_RSI_DECLINING_SELL=1
# ADX threshold above which the RSI-declining gate for SELL is automatically disabled
# (strong trending market overrides the RSI-direction check)
# FORGE_BREAKOUT_RSI_DECL_SELL_ADX_THRESHOLD=40
# Bars to look back for ADX spike-from-flat detection before allowing a SELL entry.
# Guards against entering a SELL the moment ADX spikes from a flat/ranging market —
# a spike-from-flat ADX often reverses quickly rather than sustaining a trend.
# 0 = disabled. 6 = require ADX to have been elevated for the last 30 min (6 × M5 bars).
# Default: 6. Set to 0 to disable for faster entries on ADX breakouts.
# FORGE_BREAKOUT_ADX_MIN_SELL_LOOKBACK_BARS=6
# H1 Wilder DI+/DI- directional gate: block BUY entry when H1 DI- > DI+ (bearish directional
# imbalance on the hourly). Guards against buying into a dominant bear trend on the H1.
# Only active when ADX is below FORGE_BREAKOUT_COUNTER_BUY_ADX_THRESHOLD (auto-off in strong trends).
# 0=disabled (EA default), 1=enabled (recommended for trend-following accuracy).
# FORGE_BREAKOUT_REQUIRE_H1_DI_BUY=1
#
# H1 DI gate for SELL: block SELL entries when H1 DI+ >= DI- (H1 is bullish — counter-trend SELL).
# Unlike BUY gate, NO ADX bypass — high-ADX false-breakdowns (like G5008 ADX=37.4) are the exact risk.
# 0=disabled (default), 1=enabled (strongly recommended — prevents counter-trend SELL into bull rallies).
# FORGE_BREAKOUT_REQUIRE_H1_DI_SELL=1
#
# H1 MACD histogram gate for SELL: block SELL when H1 MACD histogram >= 0 (H1 bullish momentum).
# Secondary confirmation layer — both H1 DI and H1 MACD must agree for maximum precision.
# Complements REQUIRE_H1_DI_SELL: DI catches trend direction, MACD catches momentum phase.
# 0=disabled (default, enable after validating H1 DI gate in Run 11), 1=enabled (Run 12+).
# FORGE_BREAKOUT_REQUIRE_H1_MACD_SELL=0
#
# ADX threshold above which the H1 DI gate automatically disables itself.
# When M5 ADX >= this value, the market is already in a strong trend — DI confirmation is
# redundant and may filter valid fast-rising breakouts. Set lower (e.g. 25) to keep the gate
# active in more conditions; higher (e.g. 35) to allow more momentum chasing.
# Default: 28. Used only when FORGE_BREAKOUT_REQUIRE_H1_DI_BUY=1.
# FORGE_BREAKOUT_COUNTER_BUY_ADX_THRESHOLD=28
# H1+H4 crash-SELL bypass: when both H1 and H4 are bearish, skip RSI floor + ADX spike gate (0=disabled, 1=enabled)
# FORGE_BREAKOUT_H1H4_CRASH_SELL=1
# Hard RSI lower bound for crash bypass — blocks RSI below this even with H1+H4 bear alignment
# FORGE_BREAKOUT_H1H4_CRASH_SELL_RSI_MIN=20
# Maximum ADX for crash bypass — high ADX = move already extended, higher reversal risk
# FORGE_BREAKOUT_H1H4_CRASH_SELL_ADX_MAX=40
# Minimum H1 bear trend-strength magnitude for SELL entries (filters barely-bearish H1 bias)
# FORGE_BREAKOUT_MIN_H1_BEAR_STRENGTH=0.2
# SL ATR multiplier for BB_BREAKOUT trades (SL placed ATR×mult from entry)
# FORGE_BREAKOUT_SL_ATR_MULT=2.0
# 2.7.18 — BUY-only SL widen (Run 15 G5015 fix). 0 = use FORGE_BREAKOUT_SL_ATR_MULT;
# >0 = override for BUY only. SELL path untouched. Set to 3.0 for SL-hunt protection on BUY legs.
# FORGE_BREAKOUT_BUY_SL_ATR_MULT=0
#
# 2.7.23 — BE-trail cushion (Run 17 G5002 fix). 0 = legacy tight BE+spread+5pts. >0 = SL∓mult×ATR
# below/above entry, giving breathing room in volatile markets. Captures continuation runs at the
# cost of losing guaranteed BE-lock. Typical 0.3-0.5; >2.0 effectively disables BE-trail.
# FORGE_BREAKOUT_BE_CUSHION_ATR_MULT=0
#
# 2.7.24 — Milestone 2 SL ratchet (FORGE_RATCHET_LOGIC_IDEAS.md spec section 5/6). When TP2 reached,
# ratchet SL UP to TP1 level (locks in TP1-distance of profit). SL invariant preserved.
# 0 = legacy (SL stays at cushion after TP1, only TP promoted to TP3 at TP2). 1 = ratchet enabled.
# FORGE_BREAKOUT_TP2_SL_RATCHET_ENABLED=0
#
# 2.7.25 — ATR trail per spec (peak/trough tracking). After TP1, trail SL continuously at
# peak∓atr_trail_mult×ATR. Coexists with M1 cushion + M2 ratchet. SL invariant preserved.
# FORGE_BREAKOUT_ATR_TRAIL_ENABLED=0
# FORGE_BREAKOUT_ATR_TRAIL_MULT=1.5
#
# 2.7.27 — Daily Direction Gate (Filters 1+2+3) — Run 17 G5048 fix (the -$1,666 catastrophe
# where multi-day rollover was invisible to local M5/M15/H1 gates).
# Filter 1: block BUY when D1 SMA slope < -threshold; block SELL when slope > +threshold.
#   slope = D1_SMA(period)(0) - D1_SMA(period)(lookback_days); threshold = slope_block_atr × D1_ATR(14).
# Filter 2: track intraday cumulative move from D1 open; flag bull/bear flips with hysteresis.
# Filter 3: when a flip is detected, cancel pending stops/limits within our magic range so they
#   don't fill into the new regime (canonical OrdersTotal()-1->0 iterate-down loop).
# G5048 simulation: Apr 14 close 4841 -> Apr 16 mid-day 4810 = slope -15 pts/day vs threshold -12.5 -> BLOCK BUY.
# FORGE_GATE_DAILY_DIRECTION_ENABLE=0
# FORGE_ATOM_DAILY_SMA_PERIOD=20
# FORGE_ATOM_DAILY_SMA_LOOKBACK=3
# FORGE_ATOM_DAILY_SLOPE_BLOCK_ATR=0.5
# FORGE_ATOM_DAILY_MOVE_BLOCK_ATR=0.5
# FORGE_ATOM_DAILY_MOVE_FLIP_HYSTERESIS=0.3
# FORGE_GATE_DAILY_FLIP_CANCEL_PENDING=1
# FORGE_GATE_DAILY_FLIP_CANCEL_CASCADE=1
#
# 2.7.27 — Extended TP4/TP5 staging (Run 17 G5040 +$218 winner had 53 pts of additional move after TP3).
# After TP3 reached, ratchet SL to TP2 and promote TP target to TP4 (4.0×ATR via FORGE_BREAKOUT_TP4_ATR_MULT).
# After TP4 reached, ratchet SL to TP3 and promote TP target to TP5 (5.5×ATR via FORGE_BREAKOUT_TP5_ATR_MULT).
# Gated by min ADX + TRENDING regime so chop entries stop at TP3 (current behavior).
# FORGE_BREAKOUT_TP4_STAGING_ENABLED=0
# FORGE_BREAKOUT_TP4_MIN_ADX=25
# FORGE_BREAKOUT_TP5_STAGING_ENABLED=0
# FORGE_BREAKOUT_TP5_MIN_ADX=30
# FORGE_BREAKOUT_TP5_ATR_MULT=5.5
#
# 2.7.28 — Momentum dump-catch market entry (new non-BB setup).
# Fires at market when M5 shows a fast directional impulse that BB_BREAKOUT/BB_BOUNCE
# conditions miss. Single-shot scalp — no cascade arming, smaller lot than BB setups.
# Trigger (SELL): close(0) - close(lookback) < -atr_mult × M5_ATR AND RSI<max AND ADX>min
#                 AND PSAR=ABOVE AND d1_bear_bias (v2.7.27 Filter 1) AND not in cooldown.
# Mirror for BUY (signs flipped, RSI>(100-max), PSAR=BELOW, d1_bull_bias).
# Run 17 evidence: Apr 22-29 lost ~208 pts straight bear move, only 6 BB_BREAKOUT SELLs
# fired — most dump bars never re-broke BB lower band, leaving the trend uncaught.
# Depends on v2.7.27 Filter 1 — require_d1_bias=1 means daily_direction_gate_enabled
# must also be on; otherwise this filter becomes a no-op (g_daily_bear_bias stays false).
# FORGE_DUMP_CATCH_ENABLED=0
# FORGE_DUMP_LOOKBACK_BARS=3
# FORGE_DUMP_ATR_MULT=1.5
# FORGE_DUMP_MAX_RSI=50
# FORGE_DUMP_MIN_ADX=25
# FORGE_DUMP_REQUIRE_PSAR=1
# FORGE_DUMP_REQUIRE_D1_BIAS=1
# FORGE_DUMP_COOLDOWN_SECONDS=600
# FORGE_DUMP_LOT_FACTOR=0.7
#
# 2.7.29 — Regime classifier H1-strong override (Run 18 Issue 1 fix — the "perfect setup, 5 legs only" problem).
# The inline classifier (FORGE.mq5:5658-5661) requires unanimous H1+H4 agreement for TREND_BULL/TREND_BEAR.
# H4 EMA20-EMA50 lags H1 by 3-5 hours after a regime turn, so perfect M5/H1 setups get capped at
# 5 legs because regime stays RANGE. Run 18 G5001 (Apr 1 08:40) hit this: h1_trend=+2.15, ADX=40
# but regime=RANGE → only 5 legs fired despite price moving +41pts (8×ATR) in 2 hours.
#
# Override: when h1_trend_strength is >= override_factor × trend_thr_eff AND m5_adx >= override_adx_min,
# force TREND_BULL/TREND_BEAR regardless of H4 alignment. Apr 1 G5001 had thr~0.5, h1_trend=2.15,
# adx=40 — at factor=2.0 → 2.0×0.5=1.0 threshold → 2.15 >= 1.0 → trigger (would have unlocked 10 legs).
#
# Default 0 = disabled (legacy unanimous AND-gating preserved).
# Typical enable value: 2.0 (factor) + 30 (adx min). Conservative: 2.5 + 35. Aggressive: 1.5 + 25.
# FORGE_ATOM_HTF_H1_STRONG_FACTOR=0
# FORGE_ATOM_HTF_H1_STRONG_ADX_MIN=30
#
# 2.7.31 — BB_PULLBACK_SCALP additive setup (Run 19 Issue 4 / Task #53 — catches v2.7.26-blocked bounces).
# When v2.7.26 PSAR-misalign gate would block a BB_BOUNCE entry, this fork checks if it's a "pullback
# bottom" entry (PSAR just flipped against trade direction) vs a "sustained reversal" (PSAR on wrong
# side for many bars = real trend = G5028-class bad entry). If fresh-flip + h1_trend aligned + low ADX,
# fire as BB_PULLBACK_SCALP with tight scalp geometry (SL=1×ATR, TP1=0.3×ATR, lot=0.5×, no cascade).
# Otherwise the original PSAR-misalign SKIP fires (G5028 protection preserved).
# Recovers Run 17 winners blocked Apr 2/Apr 7/Apr 8 (~$1,400+ per Run 19 sizing). Default OFF.
# FORGE_PULLBACK_SCALP_ENABLED=0                  # master toggle
# FORGE_PULLBACK_SCALP_FRESH_FLIP_BARS=3          # PSAR flip must be within last N M5 bars (default 3)
# FORGE_PULLBACK_SCALP_LOT_FACTOR=0.5             # lot multiplier vs fixed_lot — smaller than BB setups
# FORGE_PULLBACK_SCALP_SL_ATR_MULT=1.0            # SL distance in ATR units (tight)
# FORGE_PULLBACK_SCALP_TP1_ATR_MULT=0.3           # TP1 in ATR (fast scalp banking)
# FORGE_PULLBACK_SCALP_TP2_ATR_MULT=0.7           # TP2 runner
# FORGE_PULLBACK_SCALP_COOLDOWN_SECONDS=600       # 10-min cooldown per direction (one entry per pullback)
# FORGE_PULLBACK_SCALP_MAX_ADX=30                 # require ADX < this (pullback exhausting, not accelerating)
#
# 2.7.31 — Dump-catch tuning (Fix A — Run 19 Issue showed Apr 8 PM dumps had ADX 20-24, default 25 blocked them)
# FORGE_DUMP_MIN_ADX=20                            # was 25 default; allows ADX 20-24 dumps to fire
#
# 2.7.32 — Dump-catch direction-confirmation gate (Option B from Run 20 SL analysis).
# Run 20 Mar 31 showed 16 of 24 BUY losses were IMMEDIATE-SL direction failures (avg 30min, exact 1.52×ATR).
# These were single-wick triggers in chop. Confirmation gate requires the IMMEDIATELY PRIOR closed bar
# (bar 1) to also have moved in trade direction (close[1] < close[2] for SELL, close[1] > close[2] for BUY).
# Filters chop wicks without rejecting genuine momentum impulses.
# Default OFF — currently documented for separate validation run.
# Logged as SKIP `dump_bar_confirm_missing` when gate fires.
# FORGE_DUMP_REQUIRE_BAR_CONFIRM=0                 # 1 to enable (operator opt-in after validation)
#
# 2.7.19 — Failed-breakout-pullback gate (Run 15 G5013/G5015 fix). Blocks BB_BREAKOUT BUY when an
# atr_ext SKIP fired within last N bars at a higher price, AND RSI peaked >=min_peak_rsi, AND current
# RSI dropped >=min_rsi_drop from that peak. Structural fix for the fake-breakout reversal pattern.
# FORGE_BREAKOUT_FAILED_GATE_ENABLED=0
# FORGE_BREAKOUT_FAILED_LOOKBACK_BARS=4
# FORGE_BREAKOUT_FAILED_MIN_PEAK_RSI=75
# FORGE_BREAKOUT_FAILED_MIN_RSI_DROP=3
#
# 2.7.20 — Same-bar atr_ext hard block (MQL5 Liquidity Sweep article wick-rejection guard).
# When atr_ext SKIP fires in same M5 bar as TAKEN candidate, hard-block regardless of RSI.
# FORGE_BREAKOUT_FAILED_SAME_BAR_HARD_BLOCK=0
#
# 2.7.20 — PSAR alignment gate (LiteFinance: wait for stable PSAR after flip).
# BUY requires psar_state=BELOW; SELL requires psar_state=ABOVE. Blocks FLIP_* transitional states.
# FORGE_BREAKOUT_REQUIRE_PSAR_ALIGN=0
#
# 2.7.21 — Cascade regime guard (Run 15 G5040 fix). Only arm SELL STOP CONT cascade when regime
# is TREND_BULL/TREND_BEAR/VOLATILE. In RANGE regime, post-TP1 continuation is typically a stop hunt
# that reverses through cascade SL.
# FORGE_SELL_STOP_CONT_REQUIRE_TREND_REGIME=0
#
# 2.7.21 — SELL RSI floor raised 30→33 (canonical "don't sell extreme oversold").
# Blocks SELL entries when m5_rsi <= 33 (was 30). Catches G5040-style fake-breakdown shorts.
# FORGE_BREAKOUT_RSI_SELL_FLOOR=30
#
# ── BB_BREAKOUT TP targets ───────────────────────────────────────────────────
# Fallback TP1 used when direction-specific values are 0.
# FORGE_BREAKOUT_TP1_ATR_MULT=0.4
#
# Direction-specific TP1 (override fallback when > 0):
# BUY: more room — confirmed uptrend has momentum behind it.
# SELL: tighter — catch the intrabar dip before potential reversal (G5007 validated).
# Set both to 0 to use the shared FORGE_BREAKOUT_TP1_ATR_MULT fallback.
# FORGE_BREAKOUT_TP1_BUY_ATR_MULT=0.5
# FORGE_BREAKOUT_TP1_SELL_ATR_MULT=0.4
#
# Percentage of position closed at TP1 (remainder rides as runners to TP2→TP3).
# 60% = lock profit on most of the position; 40% rides.
# FORGE_BREAKOUT_TP1_CLOSE_PCT=60
#
# TP2 and TP3 — runner targets after TP1.
# TP3 is assigned as a live order target once TP2 is reached (TP staging pass).
# TP4 intentionally omitted from live targets — scalpers take TP3 and re-enter.
# FORGE_BREAKOUT_TP2_ATR_MULT=1.5
# FORGE_BREAKOUT_TP3_ATR_MULT=2.5
# FORGE_BREAKOUT_TP4_ATR_MULT=4.0   # v2.7.27 extended TP staging target (when tp4_staging_enabled=1)

# ── BB_BREAKOUT — M30 EMA BEAR CONFIRMATION (v2.7.9) ────────────────────
# Require M30 EMA20 < EMA50 for SELL entries when ADX >= m30_bear_adx_min (0=disabled, 1=enabled)
# FORGE_BREAKOUT_REQUIRE_M30_BEAR_SELL=1
# ADX floor above which the M30 bear alignment check is enforced
# FORGE_BREAKOUT_M30_BEAR_ADX_MIN=25

# ── BB_BREAKOUT — MACD HISTOGRAM GATES ──────────────────────────────────
# Require MACD histogram to be bearish (Q2/Q3) for SELL breakout entries (0=disabled, 1=enabled)
# FORGE_BREAKOUT_REQUIRE_MACD_SELL=1
# Require MACD histogram to be bullish (Q0/Q1) for BUY breakout entries (0=disabled, 1=enabled; experimental)
# FORGE_BREAKOUT_REQUIRE_MACD_BUY=0
# OsMA(fast, slow, signal) parameters — arXiv:2206.12282 MACD 4-quadrant approach
# FORGE_BREAKOUT_MACD_FAST=3
# FORGE_BREAKOUT_MACD_SLOW=10
# FORGE_BREAKOUT_MACD_SIGNAL=16

# ── BB_BREAKOUT — ADX-TIERED LOT SIZING ─────────────────────────────────
# Use M15 ADX (not M5) for lot-tier decisions to avoid ADX lag (0=disabled, 1=enabled)
# FORGE_BREAKOUT_ADX_LOT_USE_M15=1
# ADX threshold for mid-tier lot reduction (e.g. 35 = reduce lots when ADX 35–45)
# FORGE_BREAKOUT_ADX_LOT_MID_THRESHOLD=35
# ADX threshold for high-tier lot reduction (e.g. 45 = further reduce when ADX ≥ 45)
# FORGE_BREAKOUT_ADX_LOT_HIGH_THRESHOLD=45
# Lot factor applied when ADX is in the mid-tier range (0.0–1.0; e.g. 0.25 = trade at 25% base lot)
# FORGE_BREAKOUT_ADX_LOT_FACTOR_MID=0.25
# Lot factor applied when ADX is in the high-tier range (0.0–1.0; e.g. 0.125 = 12.5% base lot)
# FORGE_BREAKOUT_ADX_LOT_FACTOR_HIGH=0.125
# ADX value above which SELL breakout entries are blocked outright (move too extended)
# FORGE_BREAKOUT_ADX_SELL_BLOCK_THRESHOLD=55
# Fractional lot for SELL entries when price has pulled back inside the BB band (0.0–1.0)
# FORGE_BREAKOUT_SELL_INSIDE_BAND_LOT_FACTOR=0.25
# Maximum ATR extension from the first-entry price before a re-entry is blocked.
# Prevents chasing a fast-moving price that has already run far from the original entry —
# e.g., if Gold has moved 1.25×ATR from G5001's entry, a new entry in the same direction is skipped.
# 0.0 = disabled (EA default — no re-entry limit).
# 1.25 = block re-entry if price is already 1.25×ATR beyond first entry (recommended).
# Applies to both BUY and SELL re-entries within the same move.
# FORGE_BREAKOUT_MAX_REENTRY_ATR_EXT=1.25

# ── BB_BREAKOUT — SELL LIMIT CASCADE (Cardwell Bear Resistance) ──────────
# Arm a pending SELL LIMIT at bid + ATR × mult to catch RSI bounce into resistance (0=disabled, 1=enabled)
# FORGE_BREAKOUT_SELL_LIMIT_ENABLED=1
# ATR multiplier for SELL LIMIT L1 price placement above bid
# FORGE_BREAKOUT_SELL_LIMIT_ATR_MULT=0.4
# Lot factor for SELL LIMIT L1 (fraction of base lot; e.g. 0.125 = 1/8th lot)
# FORGE_BREAKOUT_SELL_LIMIT_LOT_FACTOR=0.125
# Expiry in M5 bars for SELL LIMIT L1 before auto-cancel
# FORGE_BREAKOUT_SELL_LIMIT_EXPIRY_BARS=6
# SELL LIMIT L2 — second cascade at 50–62% Fib retrace level (0=disabled, 1=enabled)
# FORGE_BREAKOUT_SELL_LIMIT_L2_ENABLED=0
# ATR multiplier for SELL LIMIT L2 price placement
# FORGE_BREAKOUT_SELL_LIMIT_L2_ATR_MULT=0.65
# Lot factor for SELL LIMIT L2
# FORGE_BREAKOUT_SELL_LIMIT_L2_LOT_FACTOR=0.125

# ── BB_BREAKOUT — SELL STOP CONTINUATION (v2.7.10) ──────────────────────
# [TESTER-ONLY] Arms a SELL STOP below crash low after TP1 hit to capture second impulse leg (0=disabled, 1=enabled)
# FORGE_SELL_STOP_CONT_ENABLED=0
# ATR multiplier for SELL STOP placement below crash low
# FORGE_SELL_STOP_CONT_ATR_MULT=0.40
# Lot factor for continuation SELL STOP (fraction of base lot)
# FORGE_SELL_STOP_CONT_LOT_FACTOR=0.25
# Expiry in M5 bars before SELL STOP auto-cancels (2 bars = 10 min; scalpers don't hold 40min)
# FORGE_SELL_STOP_CONT_EXPIRY_BARS=2
# Minimum RSI required for SELL STOP to arm (blocks at exhausted RSI < this)
# FORGE_SELL_STOP_CONT_MIN_RSI=25
# TP for SELL STOP CONT leg: entry - ATR×mult (0=disabled/naked).
# Previously was always 0 — G5003/G5008 gave back +8/+21pts of profit from naked cascades.
# 0.8 = tight scalp TP on the continuation leg.
# FORGE_SELL_STOP_CONT_TP_ATR_MULT=0.8

# ── BB_BREAKOUT — BUY LIMIT RECOVERY (v2.7.10) ──────────────────────────
# [TESTER-ONLY] Arms a BUY LIMIT at crash low after SELL TP1 when RSI recovers above min_rsi (0=disabled, 1=enabled)
# FORGE_BUY_LIMIT_RECOVERY_ENABLED=0
# RSI threshold indicating Bull Support zone entered — recovery confirmed (e.g. 35)
# FORGE_BUY_LIMIT_RECOVERY_MIN_RSI=35
# Lot factor for recovery BUY LIMIT (fraction of base lot)
# FORGE_BUY_LIMIT_RECOVERY_LOT_FACTOR=0.25
# Expiry in M5 bars before BUY LIMIT recovery auto-cancels
# FORGE_BUY_LIMIT_RECOVERY_EXPIRY_BARS=4
# SL ATR multiplier for recovery BUY LIMIT (placed below crash low × this multiplier)
# FORGE_BUY_LIMIT_RECOVERY_SL_ATR_MULT=1.0


# ── H4 SUPPLEMENTAL GATES (v2.7.10 — disabled by default) ──────────────
# H4 RSI gate: block SELL when H4 RSI >= sell_max (Cardwell Bear Resistance HH zone);
#              block BUY when H4 RSI <= buy_min  (Cardwell Bull Support LL zone)
# Set to 1 to enable; revert to 0 to restore pre-2.7.10 behaviour.
# FORGE_GATE_HTF_H4_RSI_ENABLE=0
# RSI value above which H4 SELL entries are blocked (Cardwell Bear Resistance exhaustion; 30–80)
# FORGE_ATOM_HTF_H4_RSI_MAX_SELL=60
# RSI value below which H4 BUY entries are blocked (Cardwell Bull Support exhaustion; 20–70)
# FORGE_ATOM_HTF_H4_RSI_MIN_BUY=40
# H4 ADX gate: block entries when H4 ADX < threshold (H4 structurally ranging — no trend on H4) (0=disabled, 1=enabled)
# FORGE_GATE_HTF_H4_ADX_ENABLE=0
# Minimum H4 ADX for SELL entries (Wilder standard minimum: 20)
# FORGE_ATOM_HTF_H4_ADX_MIN_SELL=20
# Minimum H4 ADX for BUY entries
# FORGE_ATOM_HTF_H4_ADX_MIN_BUY=20


# ── ADX HYSTERESIS (anti-fade gate) ─────────────────────────────────────
# Block BB_BOUNCE entries in TREND regime using ADX hysteresis (0=disabled, 1=enabled)
# FORGE_GATE_M5_ADX_HYSTERESIS_ENABLE=1
# Apply ADX hysteresis gate in Strategy Tester runs (0=disabled, 1=enabled)
# FORGE_GATE_M5_ADX_HYSTERESIS_APPLY_IN_TESTER=1
# ADX level above which regime transitions to TREND (hysteresis ON); blocks bounce entries
# FORGE_ATOM_M5_ADX_TREND_ENTER=25
# ADX level below which regime exits TREND (hysteresis OFF); bounces allowed again
# FORGE_ATOM_M5_ADX_TREND_EXIT=20


# ── SESSION SELL CUTOFFS ─────────────────────────────────────────────────
# Block new SELL entries after this UTC hour during NY session (0=disabled).
# 17 UTC = 1 PM EDT (original, too early — kills NY afternoon session).
# 18 UTC = 2 PM EDT (current — safe balance; G5007 loss at 17:10 from setting 20).
# 20 UTC = 4 PM EDT (NY session close — too late; opens late-session risk).
# Use FORGE_SESSION_NY_SELL_CUTOFF_UTC (wired to sync script); old SESSION_ prefix is dead.
# FORGE_SESSION_NY_SELL_CUTOFF_UTC=18
# FORGE_SESSION_LONDON_SELL_CUTOFF_UTC=0


# ── SELL LOSS GRACE (adverse-move defer) ─────────────────────────────────
# Seconds to defer a SELL loss before recording — allows brief adverse moves to recover
# FORGE_SELL_LOSS_GRACE_SEC=90
# Maximum adverse move in points allowed during grace window before forcing loss record
# FORGE_SELL_LOSS_GRACE_ADVERSE_POINTS=20


# ── ENTRY QUALITY GATE (v2.6.5+) ────────────────────────────────────────
# Minimum ATR value for a valid entry candle (raw points; e.g. 3.5 on XAUUSD = $0.35 minimum move)
# FORGE_MIN_ENTRY_ATR=3.5
# Number of M5 bars evaluated for body ratio and directional alignment
# FORGE_ENTRY_QUALITY_BARS=3
# Minimum candle body / total-range ratio required (0.0–1.0; 0.40 = body must be ≥ 40% of candle)
# FORGE_MIN_BODY_RATIO=0.40
# Minimum number of bars in the lookback that must close in the trade direction
# FORGE_MIN_DIRECTIONAL_BARS=2
# Require at least one BB band to be expanding (widening) before entry (0=disabled, 1=enabled)
# FORGE_REQUIRE_BB_EXPANSION=1


# ── INDICATORS ───────────────────────────────────────────────────────────
# Volume Profile lookback window in bars (20–500)
# FORGE_VP_LOOKBACK=100
# Number of price bins for Volume Profile calculation (10–200)
# FORGE_VP_BINS=50

# Fibonacci swing levels — VWAP-vs-Fib50 directional bias + Fib TP targets
# Enable VWAP vs Fib 50% directional bias gate (0=disabled, 1=enabled)
# FORGE_FIB_BIAS_ENABLED=1
# Enable Fibonacci TP level targeting (0=disabled, 1=enabled)
# FORGE_FIB_TP_ENABLED=1
# Swing lookback in bars for Fib high/low detection (0 = auto: 34 bars)
# FORGE_FIB_LOOKBACK=0

# RSI divergence detection (entry confirmation for bounces)
# Enable RSI divergence detection (0=disabled, 1=enabled)
# FORGE_RSI_DIV_ENABLED=1
# RSI divergence lookback in bars (5–200)
# FORGE_RSI_DIV_LOOKBACK=20
# Minimum bars to confirm a swing pivot for divergence (1–10)
# FORGE_RSI_DIV_SWING_BARS=3
# Minimum RSI magnitude difference to count as divergence (0.0–20.0)
# FORGE_RSI_DIV_MIN_RSI_DIFF=1.0
# Draw chart arrows at detected RSI divergence points (0=disabled, 1=enabled)
# FORGE_RSI_DIV_DRAW_ARROWS=1

# Parabolic SAR state tracking (informational — logged but never gates entries)
# Enable Parabolic SAR computation (0=disabled, 1=enabled)
# FORGE_PSAR_ENABLED=1
# SAR acceleration factor step (0.001–0.5)
# FORGE_PSAR_STEP=0.02
# SAR maximum acceleration factor cap (0.01–5.0)
# FORGE_PSAR_MAXIMUM=0.2


# ── SL QUALITY FLOORS ────────────────────────────────────────────────────
# Minimum SL distance as a fraction of ATR — structural SL cannot be tighter (0.3–3.0)
# FORGE_MIN_SL_ATR_MULT=0.8
# Minimum reward-to-risk ratio required before entry (e.g. 1.5 = TP must be 1.5× the SL distance)
# FORGE_MIN_RR=1.5
# Extra SL buffer in raw MT5 points added beyond ATR-based SL (e.g. 5 points = $0.50 on XAUUSD)
# FORGE_NATIVE_SL_EXTRA_BUFFER_POINTS=5


# ══════════════════════════════════════════════════════════════════════
# FORGE — SAFETY / LIMITS
# These control how many groups/trades FORGE will open and how it
# throttles after losses. Applied in scalper_config.json → safety.
# ══════════════════════════════════════════════════════════════════════
# Maximum concurrent open FORGE native groups across all directions (0=unlimited in defaults)
# Set via scalper_config.defaults.json → safety.max_open_groups; no direct .env key.
# For AEGIS-side (BRIDGE/Python), use AEGIS_MAX_OPEN_GROUPS below.

# Maximum concurrent open FORGE native groups in the same direction (0=disable cap)
# FORGE_MAX_OPEN_SAME_DIRECTION=1
#
# === DIRECTION-CAP BYPASS (v2.7.41) ===
# Comma-separated setup_type list that BYPASSES max_open_same_direction. Risk-1
# (highest-confidence) setups skip the cap so their signals are not throttled by
# a low default. Setups outside this list continue to respect the cap.
#
# Risk-1 BUY setups today: BB_BREAKOUT_RETEST, BUY_LIMIT_RECOVERY
# Risk-1 SELL setups: none unconditionally (MOMENTUM_DUMP SELL is risk-1 ONLY
#   when INTRADAY_REVERSAL composite is active — composite-state can't be
#   represented in a static setup_type list).
#
# Empty string (default) = no setup bypasses. Set to enable.
# FORGE_MAX_OPEN_SAME_DIRECTION_BYPASS_SETUPS=BB_BREAKOUT_RETEST,BUY_LIMIT_RECOVERY
#
# === REGIME-AWARE COOLDOWN BYPASS (v2.7.41) ===
# Per-setup cooldowns (BB_BREAKOUT same-dir, BB_PULLBACK_SCALP, BULL_DAY_DIP_BUY reentry)
# block second-leg continuations during strong trend days — exactly when we WANT to scalp.
# This bypass enables re-entry when the last group WON TP1 in this direction recently AND
# direction matches regime AND ADX confirms trend. Loss cooldown is NEVER bypassed.
#
# Master switch — 1=on (default), 0=off
# FORGE_COOLDOWN_BYPASS_ON_TP_WITH_TREND=1
# How recently the last TP1 must have hit (seconds). Default 600 (10 min).
# FORGE_COOLDOWN_BYPASS_WINDOW_SEC=600
# M5 ADX floor for bypass — only bypass when trend is confirmed (default 25).
# FORGE_COOLDOWN_BYPASS_MIN_ADX=25
# Anti-flicker floor — min seconds since last TP1 before bypass kicks in (default 5).
# FORGE_COOLDOWN_BYPASS_MIN_REFIRE_SEC=5
# Optional: comma-list of setup_types that bypass cooldowns UNCONDITIONALLY (no regime check).
# Use only for highest-confidence setups (risk-1).
# FORGE_COOLDOWN_BYPASS_SETUPS=

# Maximum trades allowed per trading session before FORGE stops opening new groups
# Set via config/scalper_config.defaults.json → safety.max_trades_per_session
# (no direct .env key; edit defaults and run `make scalper-env-sync`)

# Cooldown in seconds after a stop-loss hit before FORGE allows the next entry
# Set via config/scalper_config.defaults.json → safety.post_sl_cooldown_sec
# (no direct .env key; edit defaults and run `make scalper-env-sync`)

# Cooldown in seconds after any group closes at a loss (live and tester)
# Set via config/scalper_config.defaults.json → safety.loss_cooldown_sec
# (no direct .env key; edit defaults and run `make scalper-env-sync`)

# Apply the loss cooldown in Strategy Tester runs (prevents rapid whipsaw) (0=disabled, 1=enabled)
# [TESTER-ONLY toggle] Set 1 for realistic tester behaviour; 0 for throughput testing
# FORGE_TESTER_COOLDOWN_ENABLED=1

# Directional anti-whipsaw: block opposite-direction entry for N M5 bars after a close (0=disabled, 1=enabled)
# FORGE_DIRECTION_COOLDOWN_ENABLED=1
# How many M5 bars to wait before allowing an opposite-direction entry after a close
# FORGE_DIRECTION_COOLDOWN_BARS=6


# ── FORGE SIGNAL JOURNAL ─────────────────────────────────────────────────
# Enable native SQLite signal journal (records every setup FORGE evaluates) (0=disabled, 1=enabled)
# FORGE_JOURNAL_ENABLED=1
# Record skip reasons as well as actual entries in the journal (0=disabled, 1=enabled)
# FORGE_JOURNAL_RECORD_SKIPS=1
# Import completed MT5 trades into the journal for trade-aware analysis (0=disabled, 1=enabled)
# FORGE_JOURNAL_IMPORT_TRADES=1
# How many days back to import completed trades into the journal (1–365 days)
# FORGE_JOURNAL_IMPORT_DEPTH_DAYS=30
# How often to write aggregated journal stats to the log (60–3600 seconds)
# FORGE_JOURNAL_STATS_INTERVAL_SEC=300


# ── SESSION FILTER ───────────────────────────────────────────────────────
# [TESTER-ONLY] Filter entries by trading session in Strategy Tester (0=disabled, 1=enabled)
# FORGE_TESTER_SESSION_FILTER=0
# [TESTER-ONLY] Comma-separated sessions allowed in tester: LONDON,NY,ASIAN or ALL.
# (NEW_YORK alias still works — normalized to NY in ScalperTesterSessionOK.)
# FORGE_TESTER_ALLOWED_SESSIONS=ALL

# ── SESSION MINUTE-PRECISION + NY ANCHOR + KILLZONES (FORGE v2.7.36) ─────
# All windows accept minute-of-day (0..1440). -1 = use legacy hour fields
# (london_start_utc/end_utc + ny_start_utc/end_utc). When sessions_ny_anchored=1
# the EA computes session label in NY local time (DST-aware via the broker
# offset pair below); otherwise UTC. Approach B: manual offsets work
# identically in live and Strategy Tester (TimeGMT() is broken in tester).
# FORGE_SESSIONS_NY_ANCHORED=0
# FORGE_BROKER_GMT_OFFSET_WINTER=2
# FORGE_BROKER_GMT_OFFSET_SUMMER=3
# FORGE_LONDON_START_MIN=-1
# FORGE_LONDON_END_MIN=-1
# FORGE_NY_START_MIN=-1
# FORGE_NY_END_MIN=-1
# FORGE_ASIA_START_MIN=-1
# FORGE_ASIA_END_MIN=-1
# ICT killzones — minute-of-day in NY local time. Defaults match
# docs/research/ICT_KILLZONES.md. enabled=0 → killzone label always empty;
# gate_entries=1 → SessionOK requires an active killzone (use with caution).
# FORGE_KILLZONES_ENABLED=0
# FORGE_KILLZONES_GATE_ENTRIES=0
# FORGE_GATE_KILLZONE_MAX_TRADES=0  # 2.7.46 §11.5 — max TAKEN entries per killzone window (0=disabled, 3-5 typical). Blocks further entries via SKIP "killzone_trade_cap" once cap hit; counter resets on killzone transition.
# FORGE_GATE_KZ_WARMUP_MIN=0        # 2.7.52 — block entries in first N min of ANY active killzone (0=disabled, 15 typical per arongroups stop-hunt research). Emits SKIP "kz_warmup" during the warmup window. Pairs with FORGE_GATE_DUMP_JUDAS_WINDOW_BLOCK for the wider 60-min LONDON_OPEN_KZ Judas Swing rule.
# FORGE_KZ_ASIA_START_MIN=1140
# FORGE_KZ_ASIA_END_MIN=180
# FORGE_KZ_LONDON_OPEN_START_MIN=120
# FORGE_KZ_LONDON_OPEN_END_MIN=300
# FORGE_KZ_NY_OPEN_START_MIN=420
# FORGE_KZ_NY_OPEN_END_MIN=600
# FORGE_KZ_LONDON_CLOSE_START_MIN=600
# FORGE_KZ_LONDON_CLOSE_END_MIN=720


# ══════════════════════════════════════════════════════════════════════
# BOOLEAN COMPOSITES — Tier 1 (FORGE v2.7.38)
# Each composite is an EXPLICIT boolean rule built from atoms (h1_trend,
# m5_rsi, regime_label, OHLC cascades, etc.). All default-OFF — operator
# enables each independently after Run 26 validation against atom telemetry
# in SIGNALS (v2.7.37). Composite specs in docs/FORGE_INDICATOR_ATLAS.md §5.
# ══════════════════════════════════════════════════════════════════════

# ── #1 BLOCK_SELL_IN_CHOP (gate-only) ─────────────────────────────
# Block SELL entries on RANGE-regime days with H1 still bull-leaning.
# Gold retraces UP in chop — chop-SELL is high-loss-rate (Run 22 G5001 −$51).
# Applies to BB_BREAKOUT SELL, BB_BOUNCE SELL, BB_PULLBACK_SCALP SELL.
# MOMENTUM_DUMP SELL already has dump_chop_block.
# Emits gate code: entry_quality_chop_block_sell
# FORGE_BLOCK_SELL_IN_CHOP_ENABLED=0

# ── #2 INTRADAY_REVERSAL_TO_SELL_V3 (dual: BUY gate + SELL amplifier) ─
# Detect intraday pivot from bull-macro day to sustained decline.
# Atoms: h1_trend≥0.3 + M5 30min decline + M5 60min cascade + RSI≤40 +
#        (HID_BEAR | REG_BEAR | below_bbm) + price<vwap + m5_lh_cascade.
# When TRUE: (a) blocks ALL BUY setups via entry_quality_intraday_reversal_buy_block
#            (b) amplifies MOMENTUM_DUMP SELL lot by intraday_reversal_sell_lot_mult.
# Validated: Apr 2 09:00 crash, Apr 8 12:00 pivot.
# FORGE_INTRADAY_REVERSAL_SELL_ENABLED=0
# FORGE_INTRADAY_REVERSAL_SELL_LOT_MULT=2.0

# ── #3 FRACTIONAL_SELL_IN_BULL (new trigger) ──────────────────────
# Counter-regime overbought probe. NEW setup_type="FRACTIONAL_SELL_IN_BULL".
# Fires when TREND_BULL + h1_trend≥1.0 + PSAR_ABOVE + RSI 60-75 + ADX≥30
#            + bar-over-bar bearish + price near BB upper.
# Fractional lot (0.25× base) + tight TP1 0.3×ATR + no TP2 + SL 1.5×ATR.
#
# Phase 2 §10.5.1c (2026-05-12): env names moved to SETUP/GEOMETRY scopes.
# Legacy names (FORGE_FRACTIONAL_SELL_IN_BULL_*) still resolve via alias but
# print a deprecation warning at sync time. JSON keys unchanged.
# FORGE_SETUP_FRACTIONAL_SELL_IN_BULL_ENABLED=0
# FORGE_GEOMETRY_FRACTIONAL_SELL_IN_BULL_LOT_FACTOR=0.25
# FORGE_GEOMETRY_FRACTIONAL_SELL_IN_BULL_SL_ATR_MULT=1.5
# FORGE_GEOMETRY_FRACTIONAL_SELL_IN_BULL_TP1_ATR_MULT=0.3

# ── #4 BULL_DAY_DIP_BUY_V3 (new trigger, 16 atoms) ────────────────
# Catches dip-buy entries on choppy days with bullish macro bias.
# V3 OHLC additions: dist_high_atr<2, !m5_lh_cascade, long_lower_wick.
# Single TP1 (40 pips ≈ 0.65×ATR), no TP2/TP3, 300sec re-entry cooldown.
# Validated: Mar 31, Apr 1 dip-buy patterns. Blocks Apr 8 16:35 disaster.
#
# Phase 2 §10.5.1c rename — legacy FORGE_BULL_DAY_DIP_BUY_* names still work.
# FORGE_SETUP_BULL_DAY_DIP_BUY_ENABLED=0
# FORGE_GEOMETRY_BULL_DAY_DIP_BUY_LOT_MULT=1.0
# FORGE_GEOMETRY_BULL_DAY_DIP_BUY_SL_ATR_MULT=1.0
# FORGE_GEOMETRY_BULL_DAY_DIP_BUY_TP1_ATR_MULT=0.65
# FORGE_TIMING_BULL_DAY_DIP_BUY_REENTRY_COOLDOWN_SEC=300

# ── §11.4 Killzone-aware composite refinements (v2.7.51) ──────────
# All default to no-change behavior (1.0 / 0). Operator opts in.
# Reads g_regime.killzone + minutes_into_kz — EA-anchored (broker clock,
# matches forge_signals.killzone). See FORGE_REGIME_TAXONOMY.md §11.4.
# FORGE_AMPLIFY_BULL_DAY_DIP_BUY_PRIME_FACTOR=1.0   # ×N lot multiplier on BULL_DAY_DIP_BUY in prime window (NY_OPEN_KZ ∪ LONDON_CLOSE_KZ). 1.0=disabled; 1.5 typical.
# FORGE_GATE_INTRADAY_REVERSAL_REQUIRE_PRIME_KZ=0   # 1 = only fire intraday_reversal_sell amplifier inside prime window (institutional flip windows only).
# FORGE_GATE_DUMP_JUDAS_WINDOW_BLOCK=0              # 1 = block MOMENTUM_DUMP SELL in first 60 min of LONDON_OPEN_KZ (Judas Swing reversal risk).


# ══════════════════════════════════════════════════════════════════════
# NEWS FILTER — FORGE NATIVE (MT5 Economic Calendar, FORGE v2.7.6)
# Overrides config/scalper_config.defaults.json when set.
# Run `make scalper-env-sync` after changing any FORGE_NEWS_FILTER_* value.
# All 16 vars sync via scripts/sync_scalper_config_from_env.py → safety section.
# ══════════════════════════════════════════════════════════════════════
# Master toggle for the in-EA news filter (0=disabled, 1=enabled)
FORGE_NEWS_FILTER_ENABLED=1
# Comma-separated currency codes whose events trigger the news filter
FORGE_NEWS_FILTER_CURRENCIES=USD,EUR,GBP
# Minutes before a LOW-impact event during which entries are blocked (0–240)
FORGE_NEWS_FILTER_LOW_BEFORE=5
# Minutes after a LOW-impact event start during which entries are blocked (0–240)
FORGE_NEWS_FILTER_LOW_AFTER=5
# Minutes before a MEDIUM-impact event during which entries are blocked (0–240)
FORGE_NEWS_FILTER_MEDIUM_BEFORE=10
# Minutes after a MEDIUM-impact event start during which entries are blocked (0–240)
FORGE_NEWS_FILTER_MEDIUM_AFTER=15
# Minutes before a HIGH-impact event during which entries are blocked (0–240)
FORGE_NEWS_FILTER_HIGH_BEFORE=20
# Minutes after a HIGH-impact event start during which entries are blocked (0–240)
FORGE_NEWS_FILTER_HIGH_AFTER=30
# Keyword-specific overrides: KEYWORD:before,after+KEYWORD2:before2,after2
FORGE_NEWS_FILTER_SPECIAL=Non-Farm:30,60+FOMC:40,45+CPI:50,55
# Absolute minimum minutes before any high-impact event (hard floor, ignores proximity) (0–60)
FORGE_NEWS_FILTER_HARD_FLOOR_MIN=5
# Proximity fraction (0.0–1.0) at which RSI thresholds are tightened (0.5 = 50% through guard window)
FORGE_NEWS_FILTER_TIGHTEN_PCT=0.5
# Proximity fraction (0.0–1.0) at which entries are fully blocked regardless of RSI
FORGE_NEWS_FILTER_BLOCK_PCT=0.85
# RSI ceiling for BUY entries when proximity >= tighten_pct (50.0–70.0)
FORGE_NEWS_FILTER_TIGHTEN_RSI_BUY=65.0
# RSI floor for SELL entries when proximity >= tighten_pct (30.0–50.0)
FORGE_NEWS_FILTER_TIGHTEN_RSI_SELL=38.0
# How often to refresh the economic calendar cache in seconds (60–∞; 900 = 15 min)
FORGE_NEWS_FILTER_REFRESH_SEC=900
# Apply the news filter in Strategy Tester runs (0=disabled, 1=enabled)
# [TESTER-ONLY] Set 1 for realistic out-of-sample testing; 0 for throughput testing
FORGE_NEWS_FILTER_APPLY_IN_TESTER=0


# ── PENDING ORDER MANAGEMENT ─────────────────────────────────────────────
# Auto-cancel unfilled MT5 pending orders after this many seconds (0=disable)
# PENDING_ORDER_TIMEOUT_SEC=3600


# ══════════════════════════════════════════════════════════════════════
# AEGIS (risk guard — Python side)
# Validates every OPEN_GROUP before FORGE execution.
# ══════════════════════════════════════════════════════════════════════
# Default risk as % of account balance per group (e.g. 2.0 = 2%)
AEGIS_RISK_PCT=2.0
# Maximum risk % allowed per group (hard cap above AEGIS_RISK_PCT)
AEGIS_MAX_RISK_PCT=5.0
# Default ladder leg count (overridden by SIGNAL_NUM_TRADES / AUTO_SCALPER_NUM_TRADES per source)
AEGIS_NUM_TRADES=8
# Optional leg-count envelope — AEGIS resolver clamps final leg count to this range (docs/AEGIS.md §5b):
# AEGIS_MIN_NUM_TRADES=4
# AEGIS_MAX_NUM_TRADES=12
# camelCase aliases also accepted:
# aegisMinNumTrades=4
# aegisMaxNumTrades=12
# aegisNumTrades=8

# Maximum slippage tolerated for a pending fill in raw MT5 points
AEGIS_MAX_SLIPPAGE=20.0
# Minimum reward-to-risk ratio required for entry approval (e.g. 1.2 = TP1 ≥ 1.2× SL distance)
AEGIS_MIN_RR=1.2
# Daily loss limit as % of balance; BRIDGE force-switches to WATCH when exceeded
AEGIS_MAX_DAILY_LOSS=5.0
# Maximum concurrent open BRIDGE/Python groups (AEGIS side; FORGE EA has its own cap)
AEGIS_MAX_OPEN_GROUPS=3
# Maximum combined lot size across all open positions
AEGIS_MAX_LOT_TOTAL=5.0

# Lot sizing mode: "fixed" = use lot_per_trade as-is; "risk_based" = compute from balance/risk%
# AEGIS_LOT_MODE=fixed
# Minimum lot size (broker minimum for XAUUSD — MUST match broker; MT5 rejects below this)
# AEGIS_MIN_LOT=0.01
# Minimum SL distance in pips (reject signals with tighter stops; 1 pip XAUUSD = $0.10)
# AEGIS_MIN_SL_PIPS=3.0
# XAUUSD pip value per standard lot ($100/pip for 1.0 lot)
# AEGIS_PIP_VALUE_PER_LOT=100.0

# SIGNAL-source overrides (applies only to LISTENER/room signals; falls back to base AEGIS_* when unset)
# AEGIS_SIGNAL_MIN_RR=0.8
# AEGIS_SIGNAL_MIN_SL_PIPS=2.0
# AEGIS_SIGNAL_MAX_SLIPPAGE=25.0
# SIGNAL limit-orientation gate for LISTENER room entries:
#   both (default) = enforce BUY below market and SELL above market
#   buy            = enforce BUY orientation only
#   sell           = enforce SELL orientation only
#   off            = disable orientation gate (all other guards still apply)
# AEGIS_SIGNAL_LIMIT_ORIENTATION=both


# ── AEGIS MULTI-TF TREND FILTER ──────────────────────────────────────────
# Enable H1/M15/M5 trend cascade validation (true/false)
# AEGIS_H1_TREND_FILTER=true
# EMA20 vs EMA50 difference threshold ($) below which price is classified as FLAT
# AEGIS_H1_FLAT_THRESHOLD=1.0


# ── AEGIS LOT SCALING (streak-based) ─────────────────────────────────────
# Reduce lot size after N consecutive losses (integer; e.g. 3 = scale down after 3 SL hits)
AEGIS_SCALE_DOWN_LOSSES=3
# Increase lot size after N consecutive wins (integer)
AEGIS_SCALE_UP_WINS=3
# Multiplier applied when scaling down (0.0–1.0; e.g. 0.5 = half lots)
AEGIS_SCALE_DOWN_FACTOR=0.5

# Phase E — optional regime-conditioned lot multiplier (docs/AEGIS.md §5c; default OFF)
# AEGIS_REGIME_LOT_SCALE_ENABLED=false
# Minimum lot multiplier in weak regime (e.g. 0.82 = trade at 82% of base lot)
# AEGIS_REGIME_LOT_SCALE_MIN=0.82
# Maximum lot multiplier in strong aligned regime (e.g. 1.35 = trade at 135% of base lot)
# AEGIS_REGIME_LOT_SCALE_MAX=1.35
# Minimum regime confidence before any lot scaling is applied (0.0–1.0)
# AEGIS_REGIME_LOT_SCALE_MIN_CONFIDENCE=0.58
# Confidence target at which max scaling is reached
# AEGIS_REGIME_LOT_SCALE_CONF_TARGET=0.78
# Lot multiplier applied in RANGE regime (< 1.0 to reduce size in choppy markets)
# AEGIS_REGIME_LOT_SCALE_RANGE_MULT=0.94
# Lot multiplier applied in VOLATILE regime
# AEGIS_REGIME_LOT_SCALE_VOLATILE_MULT=0.87
# Hard cap on combined streak_scale × regime_mult (prevents runaway compounding)
# AEGIS_SCALE_COMBINED_MAX=2.0


# ── AEGIS ENTRY ZONE / FILL-RATE CONTROLS ────────────────────────────────
# Advisory threshold for entry zone width in pips; logged as WIDE_ZONE when exceeded
# AEGIS_MAX_ENTRY_ZONE_PIPS=8
# Action when zone is wider than max: "warn" = log only; "reject" = hard-block the group
# AEGIS_ZONE_WIDTH_ACTION=warn
# Signal entry type: "limit" = layered pending limits across zone; "market" = fill at MT5 mid immediately
# SIGNAL_ENTRY_TYPE=limit
# Cluster all legs within this pip band of the zone edge instead of spreading them (true/false)
# SIGNAL_ENTRY_ZONE_CLUSTER=false
# Cluster band width in pips when SIGNAL_ENTRY_ZONE_CLUSTER=true
# SIGNAL_ENTRY_CLUSTER_PIPS=2.0
# Cancel pending orders when group positions drain (true/false)
# PENDING_CANCEL_ON_GROUP_CLOSE=true
# Optional SIGNAL-source TP1 close-pct override (falls back to TP1_CLOSE_PCT when unset)
# SIGNAL_TP1_CLOSE_PCT=


# ── PROFIT RATCHET (auto-lock SL once a leg goes N pips green) ───────────
# Pip convention: XAU/XAG = $0.10/pip; JPY pairs = 0.01; majors = 0.0001
# Example BUY at 4620.50: TRIGGER=15pips → lock fires at 4622.00 (+$1.50); SL pinned at 4621.50.
# Enable profit ratchet (true/false; default false = opt-in)
# PROFIT_RATCHET_ENABLED=false
# Unrealised gain in pips required to fire the SL lock (e.g. 15 = +$1.50 on XAUUSD)
# PROFIT_RATCHET_TRIGGER_PIPS=15
# Pips past entry at which the SL is pinned after ratchet fires (e.g. 10 = SL at entry + $1.00)
# PROFIT_RATCHET_LOCK_PIPS=10
# Hybrid TP tightening: when leg crosses the trigger, also pull TP toward current price ±
# this many pips so any further forward move closes as TP_HIT. Set 0 to disable TP pull.
# PROFIT_RATCHET_TP_BUFFER_PIPS=5


# ── AEGIS TRADING-DAY BOUNDARY ────────────────────────────────────────────
# UTC hour at which daily P&L loss limit resets. If unset, uses SESSION_LONDON_START.
# AEGIS_SESSION_RESET_HOUR=8


# ══════════════════════════════════════════════════════════════════════
# DRAWDOWN PROTECTION
# ══════════════════════════════════════════════════════════════════════
# Circuit breaker: close all positions + force WATCH if equity drops this % from session peak
# DD_EQUITY_CLOSE_ALL_PCT=3.0
# Block new groups if floating loss exceeds this % of account balance
# DD_FLOATING_BLOCK_PCT=2.0
# Seconds to wait after a group closes at loss before AUTO_SCALPER resumes
# DD_LOSS_COOLDOWN_SEC=300


# ══════════════════════════════════════════════════════════════════════
# SENTINEL (news guard + ForexFactory calendar + RSS feeds)
# See docs/SENTINEL.md
# ══════════════════════════════════════════════════════════════════════
# Minutes before a scheduled news event during which SENTINEL blocks trading
SENTINEL_GUARD_MIN=30
# How often SENTINEL polls ForexFactory for upcoming events (seconds)
SENTINEL_POLL_SEC=60

# Post-event guard windows (minutes after scheduled start time):
# Short settle window for instant events (NFP, CPI)
# SENTINEL_POST_GUARD_MIN=5
# Long hold for speeches, FOMC, press conferences (auto-detected by keyword)
# SENTINEL_EXTENDED_GUARD_MIN=60

# Duration in seconds when operator manually bypasses the guard
# SENTINEL_OVERRIDE_DURATION_SEC=600

# ForexFactory calendar: comma-separated currency codes that trigger the guard
# USD-only: SENTINEL_CALENDAR_CURRENCIES=USD
SENTINEL_CALENDAR_CURRENCIES=USD,EUR,GBP,JPY,AUD,NZD,CAD,CHF

# Periodic event digest interval (seconds); adapts: 10min near event, 30min normally
# SENTINEL_DIGEST_INTERVAL_SEC=600

# Master toggle for RSS/news enrichment in SENTINEL (0=disable all feeds, 1=enabled)
# SENTINEL_ENABLE_NEWS_FEEDS=1

# Free RSS headlines — individual feed toggles (0=disabled, 1=enabled)
# SENTINEL_ENABLE_FXSTREET_RSS=1
# SENTINEL_FXSTREET_RSS=https://www.fxstreet.com/rss/news
# SENTINEL_ENABLE_GOOGLE_NEWS=1
# SENTINEL_GOOGLE_NEWS_QUERY=forex OR XAUUSD OR gold OR ECB OR BOJ OR FOMC OR CPI NFP
# SENTINEL_ENABLE_INVESTING_RSS=1
# DailyFX often 403 from cloud IPs — default off; test locally first
# SENTINEL_ENABLE_DAILYFX_RSS=0
# Your own RSS feeds (comma-separated, max 6):
# SENTINEL_EXTRA_RSS_URLS=
# Maximum headlines fetched per RSS feed
# SENTINEL_RSS_MAX_PER_FEED=8
# Total headline cap across all feeds
# SENTINEL_RSS_TOTAL_CAP=40
# HTTP timeout for RSS fetch requests (seconds)
# SENTINEL_RSS_TIMEOUT=12


# ══════════════════════════════════════════════════════════════════════
# BRIDGE (orchestrator)
# Controls BRIDGE loop timings and file-bus behaviour.
# ══════════════════════════════════════════════════════════════════════
# Main orchestration loop interval in seconds (1–60; lower = more responsive)
BRIDGE_LOOP_SEC=5
# How often BRIDGE calls TradingView MCP (seconds; each call is heavy — 30–120s typical)
BRIDGE_LENS_SEC=60
# How often BRIDGE checks SENTINEL for upcoming events (seconds)
BRIDGE_SENTINEL_SEC=60
# Seconds since last market_data.json write before MT5 data is considered stale
BRIDGE_MT5_STALE=120
# Relaxed stale threshold during transient file-write races (seconds; must be >= BRIDGE_MT5_STALE)
# BRIDGE_MT5_STALE_RELAXED=180
# Consecutive market_data read failures required before stale fallback trips circuit breaker
# BRIDGE_MT5_READ_FAIL_STREAK=2

# SIGNAL-path gate diagnostics (0=disabled, 1=enabled; when 1, BRIDGE writes gate_diagnostics_last.json)
# GATE_DIAGNOSTICS_ENABLED=0
# Append one-line env summary to Herald signal_skipped notifications (AEGIS always; LENS only when 1) (0=disabled, 1=enabled)
# GATE_DIAGNOSTICS_HERALD=0
# Override output path (BRIDGE + ATHENA must agree)
# GATE_DIAGNOSTICS_FILE=config/gate_diagnostics_last.json

# Optional mode lock to prevent drift (e.g., keep SIGNAL/HYBRID pinned; blank to disable)
# BRIDGE_PIN_MODE=HYBRID

# AURUM_EXEC HTTP bridge target (used by BRIDGE action AURUM_EXEC)
# AURUM_EXEC_BASE_URL=http://127.0.0.1:7842
# AURUM_EXEC_TIMEOUT_SEC=15

# Telegram result message cap for AEB action feedback (characters)
# AEB_TELEGRAM_MAX_CHARS=3000

# FORGE command queue — serialises MT5/command.json writes to avoid race conditions
# How long to wait for FORGE to confirm a command write (seconds)
# FORGE_QUEUE_ACK_TIMEOUT_SEC=8.0
# Retries per command before drop + on_drop callback
# FORGE_QUEUE_MAX_RETRIES=2

# Sync Strategy Tester journals into aurum_intelligence.db (0=disabled default; tester journals
# are ML ground truth — query FORGE_journal_*_tester.db directly).
# Set to 1 to re-enable old behaviour (e.g. for Athena Backtest tab history).
# BRIDGE_SYNC_TESTER_JOURNAL=0


# ── AEB (AURUM Execution Bridge) GUARDRAILS ─────────────────────────────
# SCRIBE_QUERY limits
# AEB_SCRIBE_MAX_ROWS=500
# AEB_SCRIBE_BUSY_MS=5000
# AEB_SCRIBE_TIMEOUT_SEC=10
# SHELL_EXEC allowlist + limits
# AEB_SHELL_EXEC_ALLOWED_PROGRAMS=python3,sqlite3
# AEB_SHELL_EXEC_ALLOWED_PATH_PREFIXES=scripts/,data/,logs/
# Block SHELL_EXEC when command origin_source matches these values (comma-separated)
# AEB_SHELL_EXEC_BLOCKED_SOURCES=TELEGRAM
# AEB_SHELL_EXEC_TIMEOUT_SEC=30
# AEB_SHELL_EXEC_MAX_OUTPUT_CHARS=4000


# ══════════════════════════════════════════════════════════════════════
# RECONCILER
# ══════════════════════════════════════════════════════════════════════
# How often RECONCILER runs (seconds; 3600 = hourly)
RECON_INTERVAL_SEC=3600
# Ignore P&L differences below this threshold in USD (prevents noisy reconcile alerts)
RECON_PNL_TOLERANCE=1.0
# Auto-close SCRIBE groups that have no MT5 exposure (true/false)
# RECON_CLOSE_STALE_GROUPS=true


# ══════════════════════════════════════════════════════════════════════
# AURUM (AI agent)
# ══════════════════════════════════════════════════════════════════════
# Claude model used by AURUM for analysis and trade decisions
AURUM_MODEL=claude-sonnet-4-20250514
# Maximum tokens per AURUM response (higher = more detail, more cost)
AURUM_MAX_TOKENS=1000
# Conversation turns retained per source (user+assistant pairs) for context/token control
# AURUM_MAX_CONV_TURNS=10
# Path to AURUM persona file (relative to python/ working directory)
SOUL_FILE=SOUL.md
# Path to AURUM capabilities reference (relative to python/ working directory)
SKILL_FILE=SKILL.md


# ══════════════════════════════════════════════════════════════════════
# WEB SEARCH (Google News RSS — free, no API key)
# Used by AURUM for live event queries. Also via ATHENA GET /api/search?q=...
# ══════════════════════════════════════════════════════════════════════
# Cache search results for this many seconds (reduces duplicate fetches)
# WEB_SEARCH_CACHE_SEC=120
# Maximum results returned per search query
# WEB_SEARCH_MAX_RESULTS=5
# HTTP timeout for search requests (seconds)
# WEB_SEARCH_TIMEOUT=8


# ══════════════════════════════════════════════════════════════════════
# ATHENA (dashboard + API)
# ══════════════════════════════════════════════════════════════════════
# Port the Athena Flask API server listens on
ATHENA_PORT=7842
# Path to the Athena React dashboard build directory
DASHBOARD_DIR=dashboard
# Set to a random secret string to require auth on state-mutating routes
# (POST /api/mode, /api/management, etc.). Leave unset for local-only use.
# ATHENA_SECRET=
# Shared secret for POST /api/scribe/query (Bearer token or X-ATHENA-SCRIBE-TOKEN header)
# Leave unset for typical local-only use.
# ATHENA_SCRIBE_QUERY_SECRET=
# SCRIBE_QUERY_MAX_ROWS=500
# SCRIBE_QUERY_BUSY_MS=5000
# Shared secret for POST /api/aurum/exec (same token BRIDGE uses for AURUM_EXEC)
# ATHENA_AURUM_EXEC_SECRET=

# Mirror each component heartbeat to Flask HTTP (non-blocking) (0=disabled, 1=enabled)
# COMPONENT_HEARTBEAT_USE_HTTP=1
# ATHENA_INTERNAL_BASE=http://127.0.0.1:7842


# ══════════════════════════════════════════════════════════════════════
# SCRIBE (database)
# ══════════════════════════════════════════════════════════════════════
# Path to primary SQLite database (relative paths resolved from repo root)
SCRIBE_DB=python/data/aurum_intelligence.db
# [TESTER-ONLY] Isolated tester journal database. Wipe between runs with: make tester-db-reset
# SCRIBE_TESTER_DB=python/data/aurum_tester.db
# Enable NDJSON audit mirror for system_events (0=disabled, 1=enabled)
# SCRIBE_AUDIT_ENABLE=1
# SCRIBE_AUDIT_JSONL=logs/audit/system_events.jsonl
# JSON snapshot at trade open stored in trade_groups.open_context (true/false; disable to save space)
# BRIDGE_OPEN_CONTEXT_ENABLE=true
# Maximum UTF-8 bytes before storing a truncated stub for open_context (see docs/DATA_CONTRACT.md)
# SCRIBE_OPEN_CONTEXT_MAX_BYTES=65536


# ══════════════════════════════════════════════════════════════════════
# LISTENER
# ══════════════════════════════════════════════════════════════════════
# Channel message cache refresh interval for ATHENA API (seconds)
# LISTENER_CACHE_REFRESH_SEC=300
# Idle heartbeat interval for component health grid (seconds)
# LISTENER_HEARTBEAT_SEC=120
# Warn if no messages ingested for this many seconds (freshness alert threshold)
# LISTENER_STALE_THRESHOLD_SEC=600
# Send chart-analysis summary to Telegram bot when signal-room media is uploaded (true/false)
# LISTENER_SIGNAL_MEDIA_SUMMARY_TO_BOT=true
# Archive signal-room uploads for replay / back-analysis (true/false)
# LISTENER_SIGNAL_MEDIA_ARCHIVE_ENABLED=true
# Directory for archived signal-room media files
# LISTENER_SIGNAL_MEDIA_ARCHIVE_DIR=data/signal_media_archive


# ══════════════════════════════════════════════════════════════════════
# VISION (image extraction for LISTENER + AURUM)
# ══════════════════════════════════════════════════════════════════════
# Enable image extraction pipeline (true/false)
# VISION_ENABLED=true
# Maximum inbound image size accepted for processing (MB)
# VISION_MAX_IMAGE_MB=8
# Automatically hold image-origin signals when extraction confidence is LOW (true/false)
# VISION_LOW_CONFIDENCE_HOLD=true
# Optional model override for vision extraction (default: same as AURUM_MODEL)
# VISION_MODEL=claude-sonnet-4-6
# Maximum image edge in pixels before downscaling for Claude vision (latency/clarity balance)
# VISION_MAX_EDGE_PX=1568
# Run a second focused pass on the price axis when first pass is LOW confidence or empty (true/false)
# VISION_SECOND_PASS=true
# Optional OCR numeric-hint fallback (requires opencv + pytesseract + local tesseract binary) (true/false)
# VISION_OCR_FALLBACK=true


# ══════════════════════════════════════════════════════════════════════
# SESSION BOUNDARIES (UTC hours — XAUUSD kill zones)
# ASIAN wraps midnight when START > END (e.g. 22–08 = Tokyo/Sydney into London).
# Flat range when START < END (e.g. 1–8 = main Tokyo hours only).
# ══════════════════════════════════════════════════════════════════════
SESSION_ASIAN_START=22
SESSION_ASIAN_END=8

# London and NY windows use local market hours (DST-aware via TZ variables).
SESSION_LONDON_TZ=Europe/London
SESSION_LONDON_LOCAL_START=8
SESSION_LONDON_LOCAL_END=13
SESSION_NY_TZ=America/New_York
SESSION_LONDON_NY_LOCAL_START=8
SESSION_LONDON_NY_LOCAL_END=12
SESSION_NY_LOCAL_START=12
SESSION_NY_LOCAL_END=17

# Legacy UTC fields kept for backward compatibility / older tools
SESSION_LONDON_START=8
SESSION_LONDON_END=13
SESSION_LONDON_NY_START=13
SESSION_LONDON_NY_END=17
SESSION_NY_START=17
SESSION_NY_END=22

# Sydney kill-zone uses local market time (DST-aware via SESSION_SYDNEY_TZ)
SESSION_SYDNEY_TZ=Australia/Sydney
SESSION_SYDNEY_LOCAL_START=9
SESSION_SYDNEY_LOCAL_END=17

# Daily Sydney-open reminder (posted once per Sydney local date) (true/false)
SYDNEY_OPEN_ALERT_ENABLED=true
# Grace window in minutes after Sydney open before the reminder fires
SYDNEY_OPEN_ALERT_GRACE_MIN=5


