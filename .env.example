# ── v2.7.60 — MOMENTUM_DUMP V2 composite (catch G5001/G5002, block G5003 exhaustion) ──
# Replaces over-blocking dump_sell_h1_max=0.5 with multi-atom alignment:
#   SELL needs: h4≤0 + macd<0 + price below VWAP/POC by ≥atr_min×ATR
#   Exhaustion-block: ADX≥max_adx AND RSI≤late_rsi_block (SELL) or RSI≥late_rsi_block (BUY)
# G5001 (h4=-0.88, macd=-0.79, ADX=33.9) ✓ TAKE | G5003 (ADX=43.9, RSI=35.1) ✗ BLOCK
# FORGE_GATE_DUMP_V2_ENABLED=1                 # master toggle
# FORGE_GATE_DUMP_SELL_H4_MAX=0.0              # SELL needs H4 bearish/neutral
# FORGE_GATE_DUMP_BUY_H4_MIN=0.0               # BUY needs H4 bullish/neutral
# FORGE_GATE_DUMP_SELL_MACD_MAX=0.0            # SELL needs macd_hist < this
# FORGE_GATE_DUMP_BUY_MACD_MIN=0.0             # BUY needs macd_hist > this
# FORGE_GATE_DUMP_SELL_VWAP_ATR_MIN=0.3        # SELL: price below VWAP by ≥ this×ATR
# FORGE_GATE_DUMP_BUY_VWAP_ATR_MIN=0.3         # BUY: price above VWAP by ≥ this×ATR
# FORGE_GATE_DUMP_SELL_POC_ATR_MIN=0.3         # SELL: price below POC by ≥ this×ATR
# FORGE_GATE_DUMP_BUY_POC_ATR_MIN=0.3          # BUY: price above POC by ≥ this×ATR
# FORGE_GATE_DUMP_MAX_ADX=42.0                 # exhaustion-block ADX ceiling
# FORGE_GATE_DUMP_SELL_LATE_RSI_BLOCK=36.0     # SELL exhaustion: block when adx≥max_adx AND rsi ≤ this
# FORGE_GATE_DUMP_BUY_LATE_RSI_BLOCK=64.0      # BUY exhaustion: block when adx≥max_adx AND rsi ≥ this

# ── v2.7.69 — ICT market-structure gates (wires v2.7.68 BOS + v2.7.65 signed velocity into trade decisions) ──
# Run 29 lost $4,200+ on BLR_BUY falling-knife catches (G5015/G5016/G5027/G5032) and $3,300+ on
# BB_BREAKOUT BUY second-leg-at-top traps (G5005/G5022/G5023/G5025/G5026) — all because the setups
# checked lagging h1_trend/h4_trend instead of M5 structure (BOS direction + signed velocity).
# FORGE_GATE_BLR_BUY_BLOCK_ON_BEARISH_BOS=1            # BLR_BUY: block when g_eval_bos_direction == -1
# FORGE_GATE_BLR_BUY_MIN_VELOCITY_5BAR_SIGNED=-1.0     # BLR_BUY: block when (close[0]-close[5])/ATR ≤ this (fast fall)
# v2.7.80 — BLR capitulation override (Apr 6 03:30 @ 4603 RSI 23 + Apr 14 13:39 @ 4752 RSI 26.2 V-bottom fix)
#   Bypasses falling-velocity gate when ≥N of 5 capitulation atoms confirm V-flush (not grind):
#     A1 m5_rsi ≤ rsi_max | A2 close < bb_l | A3 -velocity_5bar ≥ displacement_min_atr
#     A4 m5_atr_ratio_5bar ≥ atr_ratio_min | A5 long_lower_wick || m5_doji
#   Uses tighter SL + close TPs + fixed small lot (capitulation = high-risk wick catch).
# FORGE_GATE_BLR_BUY_CAPITULATION_OVERRIDE_ENABLED=1         # 1=ON, bypass vel gate on V-flush
# FORGE_GATE_BLR_BUY_CAPITULATION_MIN_ATOMS=3                # atoms needed to bypass (of 5)
# FORGE_GATE_BLR_BUY_CAPITULATION_RSI_MAX=28.0               # A1: m5_rsi ≤ this (deep oversold)
# FORGE_GATE_BLR_BUY_CAPITULATION_DISPLACEMENT_MIN_ATR=1.5   # A3: -velocity_5bar ≥ this (sharp drop)
# FORGE_GATE_BLR_BUY_CAPITULATION_ATR_RATIO_MIN=1.3          # A4: m5_atr_ratio_5bar ≥ this (vol expansion)
# FORGE_GEOMETRY_BLR_BUY_CAPITULATION_LOT=0.30               # fixed lot for capitulation fires
# FORGE_GEOMETRY_BLR_BUY_CAPITULATION_SL_ATR_MULT=1.5        # SL = bb_l - this×ATR
# FORGE_GEOMETRY_BLR_BUY_CAPITULATION_TP1_ATR_MULT=0.5       # TP1 = entry + this×ATR
# FORGE_GEOMETRY_BLR_BUY_CAPITULATION_TP2_ATR_MULT=1.5       # TP2 = entry + this×ATR
# v2.7.81 — ASIA_CAPITULATION_BUY (Apr 6 03:30 @ 4603 RSI 23 pre-London V-flush)
#   Session-agnostic — bypasses session_off gate during the Asia window (default 22→07 UTC).
#   Same 5-atom composite as v2.7.80 BLR capitulation override (RSI / BB pierce / drop /
#   ATR expansion / wick||doji). Fixed lot pin (0.20). Catches bottoms before London opens.
# FORGE_SETUP_ASIA_CAPITULATION_BUY_ENABLED=1                  # 1=ON, fire even when session_off would block
# FORGE_GATE_ASIA_CAPITULATION_BUY_MIN_ATOMS=3                 # atoms needed to fire (of 5)
# FORGE_GATE_ASIA_CAPITULATION_BUY_RSI_MAX=28.0                # A1: m5_rsi ≤ this
# FORGE_GATE_ASIA_CAPITULATION_BUY_DISPLACEMENT_MIN_ATR=1.5    # A3: -velocity_5bar ≥ this
# FORGE_GATE_ASIA_CAPITULATION_BUY_ATR_RATIO_MIN=1.3           # A4: m5_atr_ratio_5bar ≥ this
# FORGE_TIMING_ASIA_CAPITULATION_BUY_SESSION_START_UTC=22      # window start hour (UTC; wraps midnight if > end)
# FORGE_TIMING_ASIA_CAPITULATION_BUY_SESSION_END_UTC=7         # window end hour (UTC, exclusive)
# FORGE_GEOMETRY_ASIA_CAPITULATION_BUY_LOT=0.20                # fixed lot for Asia capitulation fires
# FORGE_GEOMETRY_ASIA_CAPITULATION_BUY_SL_ATR_MULT=1.5         # SL = bb_l - this×ATR
# FORGE_GEOMETRY_ASIA_CAPITULATION_BUY_TP1_ATR_MULT=0.5        # TP1 = entry + this×ATR
# FORGE_GEOMETRY_ASIA_CAPITULATION_BUY_TP2_ATR_MULT=1.5        # TP2 = entry + this×ATR
# FORGE_TIMING_ASIA_CAPITULATION_BUY_COOLDOWN_SEC=1800         # 30 min re-entry cooldown (thin Asia liquidity)
# FORGE_GATE_BREAKOUT_BUY_EXHAUSTION_RSI=72.0          # BB_BREAKOUT BUY: RSI triggering exhaustion check
# FORGE_GATE_BREAKOUT_BUY_BLOCK_EXHAUSTION_WITHOUT_BOS=1   # BB_BREAKOUT BUY: block when RSI ≥ above AND BOS != +1
# v2.7.73 — VWAP-distance gate (BB_BREAKOUT BUY/SELL overextension from value)
# FORGE_GATE_BREAKOUT_BUY_MAX_VWAP_DIST_ATR=2.5     # block BB_BREAKOUT BUY when (price-VWAP)/ATR > this
# FORGE_GATE_BREAKOUT_SELL_MAX_VWAP_DIST_ATR=2.5    # block BB_BREAKOUT SELL when (VWAP-price)/ATR > this
# v2.7.74 — BB_BREAKOUT BUY conviction amplifier (multi-atom-confirmed setups fire more legs + ride further)
# FORGE_SETUP_BREAKOUT_BUY_CONVICTION_ENABLED=1
# FORGE_GATE_BREAKOUT_BUY_CONVICTION_MIN_ATOMS=4        # need 4 of 6 atoms aligned
# FORGE_GEOMETRY_BREAKOUT_BUY_CONVICTION_INITIAL_LEGS=5 # fire 5 immediate legs (was 3)
# FORGE_GEOMETRY_BREAKOUT_BUY_CONVICTION_TP1_CLOSE_PCT=50  # close 50% at TP1 (was 70%) — more for runner

# ── v2.7.70 — Pyramid kill on adverse direction (caps G5032-class 8-leg pyramid growth) ──
# When a group's net P&L drops below -max_loss_usd AND M5 signed velocity is still adverse
# to the trade direction by ≥ velocity_threshold ×ATR, freeze further staged-adds. G5032
# Run 29 lost -$2,166 by letting an 8-leg BLR_BUY pyramid grow into a falling knife —
# this would have capped it at ~3 legs (~$1,000 loss instead).
# FORGE_GATE_PYRAMID_KILL_ENABLED=1
# FORGE_GATE_PYRAMID_KILL_MAX_LOSS_USD=50.0           # freeze when group P&L ≤ -$50
# FORGE_GATE_PYRAMID_KILL_VELOCITY_THRESHOLD=0.5      # AND adverse signed velocity ≥ 0.5×ATR

# ── v2.7.70 — NY_SESSION_BEARISH_BREAKOUT_SELL (captures 220pt+ session-open descents) ──
# Run 29 missed the entire Apr 1→2 (-232pt) + Apr 6→7 (-143pt) + Apr 8 (-80pt) bearish moves
# because every existing SELL setup requires HTF bearish confirmation (h1/h4). HTF lags M5 by
# hours — by the time h1 flipped, the moves were over. This setup deliberately ignores
# h1/h4 and reads M5 structure directly: signed velocity + macd_slope + BB_m + day-low room.
# Window: first 90min of LONDON_OPEN_KZ or NY_OPEN_KZ.
# FORGE_SETUP_NY_SESSION_BEARISH_SELL_ENABLED=1
# FORGE_TIMING_NY_SESSION_BEARISH_SELL_KZ_MAX_MIN=90        # only fire within first N min of KZ
# FORGE_GATE_NY_SESSION_BEARISH_SELL_MIN_VELOCITY=1.5       # signed velocity ≤ -this×ATR
# FORGE_GATE_NY_SESSION_BEARISH_SELL_MAX_RSI=50.0           # RSI < this (room to fall)
# FORGE_GATE_NY_SESSION_BEARISH_SELL_ROOM_MIN_ATR=1.0       # (close - day_low) ≥ this×ATR
# FORGE_GEOMETRY_NY_SESSION_BEARISH_SELL_SL_ATR_MULT=3.5    # wide SL (judas-swing absorber)
# FORGE_GEOMETRY_NY_SESSION_BEARISH_SELL_TP1_ATR_MULT=1.0
# FORGE_GEOMETRY_NY_SESSION_BEARISH_SELL_TP2_ATR_MULT=2.5
# FORGE_TIMING_NY_SESSION_BEARISH_SELL_COOLDOWN_SEC=0       # let conditions decide
# FORGE_GEOMETRY_NY_SESSION_BEARISH_SELL_LOT_FACTOR=1.0

# ── v2.7.61 — Day-extreme distance gate (Apr 13 top-of-range BUYs fix) ──
# Block MOMENTUM_DUMP BUY too close to day_high (overextended top) / SELL too close to day_low.
# Apr 13 G5087/G5098 fired ~0.05×ATR from day_high → blocked. Winners 1×+ATR away → preserved.
# FORGE_GATE_DUMP_BUY_MAX_DIST_FROM_DAY_HIGH_ATR=0.5
# FORGE_GATE_DUMP_SELL_MAX_DIST_FROM_DAY_LOW_ATR=0.5

# ── v2.7.62 — Distance amplifier (reward G5092-class deep-room entries) ──
# Tiered lot multiplier based on (day_high − price)/atr for BUY (or price − day_low for SELL).
# Tier 1 (≥ threshold_atr): lot × factor.  Tier 2 (≥ strong_threshold_atr): lot × strong_factor.
# G5092 dist=3.0×ATR → strong_factor=2.0× = +$10 win → +$20 projected.
# FORGE_GEOMETRY_DUMP_DIST_AMPLIFIER_ENABLED=1
# FORGE_GEOMETRY_DUMP_DIST_AMPLIFIER_THRESHOLD_ATR=1.5
# FORGE_GEOMETRY_DUMP_DIST_AMPLIFIER_FACTOR=1.5
# FORGE_GEOMETRY_DUMP_DIST_AMPLIFIER_STRONG_THRESHOLD_ATR=3.0
# FORGE_GEOMETRY_DUMP_DIST_AMPLIFIER_STRONG_FACTOR=2.0

# ── v2.7.63 — Killzone-tier amplifier (operator: "kills move fast within secs") ──
# Reads g_regime.killzone + g_regime.minutes_into_kz (already populated each tick from ICT KZ map).
# Peak liquidity 0-5min → de-risk 60+min. Block in dead zones between KZs (no_zone_factor=0).
# FORGE_GATE_DUMP_KZ_AMPLIFIER_ENABLED=1
# FORGE_TIMING_DUMP_KZ_TIER1_MAX_MIN=5.0      # 0-5 min in KZ
# FORGE_GEOMETRY_DUMP_KZ_TIER1_FACTOR=2.0     # peak liquidity 2.0× lot
# FORGE_TIMING_DUMP_KZ_TIER2_MAX_MIN=15.0     # 5-15 min in KZ
# FORGE_GEOMETRY_DUMP_KZ_TIER2_FACTOR=1.5     # strong edge 1.5×
# FORGE_TIMING_DUMP_KZ_TIER3_MAX_MIN=30.0     # 15-30 min
# FORGE_GEOMETRY_DUMP_KZ_TIER3_FACTOR=1.0     # normal 1.0×
# FORGE_TIMING_DUMP_KZ_TIER4_MAX_MIN=60.0     # 30-60 min
# FORGE_GEOMETRY_DUMP_KZ_TIER4_FACTOR=0.85    # fading edge 0.85×
# FORGE_GEOMETRY_DUMP_KZ_TIER5_FACTOR=0.6     # 60+ min: stale, de-risk to 0.6×
# FORGE_GEOMETRY_DUMP_KZ_NO_ZONE_FACTOR=0.0   # Between KZs: 0.0 = block (1.0 = no-op, 0.5 = fractional)

# ── v2.7.84 — 3-layer entry-gating (UMCG + CVCSM + BB_EXHAUSTION_REVERSAL) ──
# UMCG = Universal Market Condition Gate. 7-atom PEMCG_BUY + 7-atom PEMCG_SELL composites
# evaluated stateless at every setup trigger. Catches G5006 (-$1,760) + G5015 (-$564)
# reversal-trap losses. See docs/FORGE_CASE_STUDY_G5006_INFLECTION_POINT.md.
# v2.7.86 — threshold raised 3→5: supermajority vote. Run 4 showed 3/7 majority-minus-one
# blocked 55,304 range bars at RSI 30-70 (NOT exhaustion). G5006 (6/7) + G5015 (5/7) still blocked at 5.
# FORGE_GATE_UMCG_ENABLED=1
# FORGE_GATE_UMCG_BUY_BLOCK_THRESHOLD=5     # >=5 of 7 atoms -> block BUY (supermajority)
# FORGE_GATE_UMCG_SELL_BLOCK_THRESHOLD=5    # >=5 of 7 atoms -> block SELL (mirror)
# FORGE_GATE_UMCG_PEMCG_RSI_OVERBOUGHT=65.0    # v2.7.88 — A1: BUY-trap when m5_rsi >= this (was 70; lowered to catch post-peak retest @ RSI 65-70)
# FORGE_GATE_UMCG_PEMCG_RSI_OVERSOLD=35.0      # v2.7.88 — A1: SELL-trap when m5_rsi <= this (was 30; mirror)
# FORGE_GATE_UMCG_PEMCG_BODY_PCT_MAX_WEAK=0.5  # A2: weak candle if body_pct < this
# FORGE_GATE_UMCG_PEMCG_ATR_RATIO_MAX_CONTRACT=1.0  # A6: volatility contracting if < this
# FORGE_GATE_UMCG_PEMCG_BB_DIST_ATR_THRESHOLD=0.3   # A5: no real breakout if |close-bb|/atr < this
# ── v2.7.105 — Day-Type Classifier (DTC): PEMCG modifier + Day-Bias hard block ─
# Solves the "PEMCG_SELL fires 63,716× during a 140pt bear move" over-blocking problem
# discovered in Run 36 v2.7.102 monitoring (2026-05-14). The fix uses INTRADAY indicators
# (VWAP-distance + M15 ADX + H1 DI dominance) — NOT h1_trend_strength which lags 1+ hour
# during fresh reversals. When confirmed bear day:
#   - PEMCG_SELL warning count is de-weighted (subtract dtc_pemcg_bypass_atoms, default 2)
#     so direction-correct SELL continuation entries pass the block threshold
#   - BUY setups (knife-catches) are hard-blocked via new gate_reason: bear_day_buy_block
#     unless they're in the exempt list (default: BB_EXHAUSTION_REVERSAL_BUY only)
# Mirror for confirmed bull day. FRACTIONAL_SELL_IN_BULL exempt from bull_day_sell_block.
# Industry citations:
#   - https://www.volity.io/forex/rsi-indicator/  (ADX gates RSI continuation vs reversal)
#   - https://www.mql5.com/en/blogs/post/767595  (VWAP as XAUUSD intraday sentiment)
#   - https://alchemymarkets.com/education/strategies/hidden-bearish-divergence/  (continuation pattern)
# All knobs default-OFF; flip via FORGE_COMPOSITE_DTC_ENABLED=1 + sub-flags.
# FORGE_COMPOSITE_DTC_ENABLED=0
# FORGE_COMPOSITE_DTC_PEMCG_MODIFIER_ENABLED=0
# FORGE_COMPOSITE_DTC_DAY_BIAS_BLOCK_ENABLED=0
# FORGE_GATE_DTC_VWAP_DIST_ATR_THRESHOLD=1.5     # |price-vwap|/atr ≥ this = strongly off VWAP (Run 36 bear avg: 4.18)
# FORGE_GATE_DTC_M15_ADX_MIN=25                  # M15 ADX ≥ this = trend strength confirmed
# FORGE_GATE_DTC_H1_DI_DOMINANCE_MIN=5.0         # |DI+ − DI−| ≥ this = clear bear/bull direction
# FORGE_GATE_DTC_PEMCG_BYPASS_ATOMS=2            # subtract from warnings when day-type matches direction
# FORGE_GATE_DTC_EXEMPT_BUY_SETUPS=BB_EXHAUSTION_REVERSAL_BUY  # comma-list exempt from bear_day_buy_block
# FORGE_GATE_DTC_EXEMPT_SELL_SETUPS=FRACTIONAL_SELL_IN_BULL,BB_EXHAUSTION_REVERSAL_SELL  # exempt from bull_day_sell_block

# ── v2.7.107 — DTC 5-state classifier (ICT-canonical) ─
# Adds H4 trend agreement as a fourth axis to the v2.7.105 intraday triad. Distinguishes:
#   - BULL_TREND_ALIGNED: intraday bull + H4 bull (trend day; block SELLs, de-weight BUY PEMCG)
#   - BEAR_TREND_ALIGNED: intraday bear + H4 bear (trend day; block BUYs, de-weight SELL PEMCG)
#   - COUNTER_TREND_BULL: intraday bull bounce inside bear H4 (knife-catch BUY risk; G5021 case)
#   - COUNTER_TREND_BEAR: intraday bear dip inside bull H4 (OTE BUY setup at H4 demand; G5016 case)
#   - NEUTRAL: no triad agreement (pre-DTC behaviour)
# Run 36 G5021 -$498 + G5026 -$399 losses were both counter-H4 entries that v2.7.105 couldn't
# catch (M15 ADX 22.2 just below the 25 threshold). 5-state's H4 axis catches them.
# ICT framework: trend-aligned + OTE re-entry + fractional counter-bias = 3 entry classes.
# Reference: tradeciety.com/multiple-time-frame-analysis (H4 = canonical bias TF for intraday).
# All knobs default-OFF; flip via FORGE_COMPOSITE_DTC_5STATE_ENABLED=1 + sub-flags.
# FORGE_COMPOSITE_DTC_5STATE_ENABLED=0      # master: 0=v2.7.105 binary behaviour, 1=v2.7.107 5-state
# FORGE_GATE_DTC_H4_TREND_MIN_AGREEMENT=0.5 # |h4_trend| ≥ this for H4 bias to be "decided"
# FORGE_GATE_DTC_BLOCK_COUNTER_TREND_BUYS=0  # block BUYs in COUNTER_TREND_BULL (catches G5021)
# FORGE_GATE_DTC_BLOCK_COUNTER_TREND_SELLS=0 # block SELLs in COUNTER_TREND_BEAR (mirror)

# ── v2.7.108 — DTC-aware SL/TP geometry widener (R:R matching on trend-aligned days) ─
# Origin: Apr-08 G5024 cascade BUY_STOP_CONT case. Price ran 4626 → 4810+ in one day (184pt
# rally). 5 cascade legs entered at 4756.18 with SL 4737.10 (19pt = 1.40×entry_atr 13.64).
# The rally pulled back 19pt INSIDE the move, stopped all 5 legs, then ran to 4810+
# (the legs missed the move). Loss: -$2,456 across 5 legs.
#
# Industry rule (per mql5.com/blogs/769205 SL strategies 2026):
#   "Volatility-aware ATR multiples > fixed pip. Swing trading 1hr: 2.5×ATR. Chop: 1.5×ATR.
#    Adaptive stop based on regime — tighten on chop, widen on trends."
#
# Two widen factors applied multiplicatively to existing cascade SL/TP ATR multipliers
# when DTC state == TREND_ALIGNED matching cascade direction. R:R is preserved by widening
# BOTH SL and TP together. Default-OFF; flip via FORGE_COMPOSITE_DTC_GEOMETRY_WIDEN_ENABLED=1.
# FORGE_COMPOSITE_DTC_GEOMETRY_WIDEN_ENABLED=0
# FORGE_GEOMETRY_DTC_TREND_ALIGNED_SL_WIDEN_FACTOR=1.0   # 1.0=no widen; rec 1.67 → 1.5×1.67=2.5×ATR
# FORGE_GEOMETRY_DTC_TREND_ALIGNED_TP_WIDEN_FACTOR=1.0   # 1.0=no widen; rec 2.0 to capture trend run

# ── v2.7.109 — Exempt-list conditional override (momentum-vs-exhaustion RSI gate) ─
# Origin: Apr-08 G5028 -$2,488. BB_EXHAUSTION_REVERSAL_SELL fired at 4773-4791 with RSI 75.7
# → 79.7 during a confirmed bull rally to 4810+. The setup was on dtc_exempt_sell_setups
# (intentional counter-trade capture) but RSI 75-80 in TREND_ALIGNED state means MOMENTUM,
# not EXHAUSTION (per volity.io: high ADX + RSI extreme = continuation, not reversal).
# Override: when TREND_ALIGNED state matches direction + setup is exempt + RSI is in the
# trend's extreme momentum zone → override the exemption and let bear_day_buy_block /
# bull_day_sell_block fire normally. Default-OFF. FRACTIONAL_SELL_IN_BULL NOT affected
# (it's fractional sizing for momentum probes — intentional).
# FORGE_COMPOSITE_DTC_EXEMPT_OVERRIDE_ENABLED=0
# FORGE_GATE_DTC_EXEMPT_OVERRIDE_SELL_RSI_MIN=75.0   # bull-aligned + SELL exempt + RSI ≥ this → override
# FORGE_GATE_DTC_EXEMPT_OVERRIDE_BUY_RSI_MAX=25.0    # bear-aligned + BUY exempt + RSI ≤ this → override
# FORGE_GATE_DTC_EXEMPT_OVERRIDE_BUY_SETUPS=BB_EXHAUSTION_REVERSAL_BUY
# FORGE_GATE_DTC_EXEMPT_OVERRIDE_SELL_SETUPS=BB_EXHAUSTION_REVERSAL_SELL

# ── v2.7.112 — ISS (ICT Structure Score) — scaffolding only (atoms stubbed, default-OFF) ──
# Replaces v2.7.110 CES. ISS = 0-10 score computed per setup-trigger from 3 ICT structure atoms:
#   +5 MSS (Market Structure Shift) — full-body close beyond prior swing in trade direction
#   +3 FVG (Fair Value Gap) — price inside active FVG retracement zone aligned with direction
#   +2 ChoCH supporting — recent counter-trend ChoCH confirms regime turn
# HARD GATE (NOT score-based): iss_choch_against → SKIP iss_choch_against_block
# Threshold tiers (encoded from ICT methodology, not calibrated):
#   ≥ 8  high-conviction (MSS + FVG + ChoCH support)
#   ≥ 5  standard (MSS alone or MSS + one confluence)
#   < 5  SKIP iss_below_threshold (no structural confirmation)
# v2.7.112 SCAFFOLDING NOTE: atom detection is STUBBED (all return 0). Real MSS/ChoCH/FVG
# detectors require a swing-pivot tracker + FVG state tracker — shipping in v2.7.113-115.
# v2.7.112 lands the schema, knobs, score-compute infrastructure, and logging plumbing only.
# See docs/ICT-Structure-Score.md for atom definitions + 4-version migration plan.
# FORGE_COMPOSITE_ISS_ENABLED=0
# FORGE_GATE_ISS_MIN_THRESHOLD=5                # = MSS-mandatory bar (consumed only by gate-mode)
# FORGE_GATE_ISS_BLOCK_BELOW_THRESHOLD=0        # gate toggle — default-OFF (instrumentation-only ship)
# v2.7.118+ — Mode C reservation (docs/FORGE_PEMCG_ICT_INTEGRATION.md §3.3).
# When ON, ISS atoms can override PEMCG composite block decisions for ICT-structure-strong setups.
# Default OFF until the structure detectors graduate from scaffolding (v2.7.113-115).
# FORGE_GATE_ISS_C_OVERRIDE_PEMCG_ENABLED=0
# FORGE_GATE_ISS_WEIGHT_MSS=5
# FORGE_GATE_ISS_WEIGHT_FVG=3
# FORGE_GATE_ISS_WEIGHT_CHOCH_SUPPORT=2
# FORGE_TIMING_ISS_FVG_MAX_AGE_BARS=12          # M5 bars — FVG age cap before expiry
# FORGE_GATE_ISS_FVG_MAX_FILL_PCT=0.5           # FVG mitigation threshold (50% retraced = consumed)

# ─────────────────────────────────────────────────────────────────────────────
# v2.7.118 — ICT Phase 1 (modular)
# First modular FORGE component — see docs/MQL5_MODULAR_EA_DESIGN.md
# Module: ea/include/Forge/IctStructure.mqh
# Default OFF — atoms compute + log to SIGNALS but no gate fires until
# iss_block_below_threshold=1 (separate later version).
# Wire-up: FORGE.mq5 #include <Forge\IctStructure.mqh> resolves via the
# compile script's recursive sync of ea/include/**/*.mqh → Wine MQL5/Include/.
# ─────────────────────────────────────────────────────────────────────────────
# Master MSS atom flag — computes Market Structure Shift (body-close break + displacement)
# FORGE_ICT_MSS_ENABLED=0
# Master FVG atom flag — maintains 3-candle Fair Value Gap ring buffer + mitigation tracking
# FORGE_ICT_FVG_ENABLED=0
# Fractal lookback bars on each side of the swing-pivot centre (typical 2-5; default 3)
# FORGE_ICT_SWING_LOOKBACK=3
# MSS displacement threshold: body / ATR ratio required for the structure-break candle (matches DirLock 0.5)
# FORGE_ICT_MSS_DISPLACEMENT_ATR_MULT=0.5
# FVG minimum size in ATR units (gaps smaller than this are filtered as noise)
# FORGE_ICT_FVG_MIN_SIZE_ATR_MULT=0.15

# ─────────────────────────────────────────────────────────────────────────────
# v2.7.120 — ICT Phase 2 (modular) — ChoCH + liquidity sweep + kill zone
# Second modular FORGE component — see docs/MQL5_MODULAR_EA_DESIGN.md
# Module: ea/include/Forge/IctLiquidity.mqh (depends on IctStructure.mqh)
# Default OFF — atoms compute + log to SIGNALS when enabled; no new SKIP gate.
# Wires real values into g_iss_choch_support / g_iss_choch_against (was stubbed 0).
# Score ceiling lifted 8 → 10 when MSS + FVG + ChoCH_support all fire.
# ─────────────────────────────────────────────────────────────────────────────
# Master ChoCH atom flag — computes Change of Character (internal swing break w/ displacement)
# FORGE_ICT_CHOCH_ENABLED=0
# Master liquidity-sweep tracker flag — maintains equal-H/L pools + sweep+rejection detection
# FORGE_ICT_LIQUIDITY_SWEEP_ENABLED=0
# ChoCH internal-structure lookback in M5 bars (window for counting recent ChoCH events)
# FORGE_ICT_CHOCH_LOOKBACK_BARS=5
# Liquidity-sweep recency window in M5 bars (how long a swept pool stays "recent" for SIGNALS)
# FORGE_ICT_LIQUIDITY_SWEEP_WINDOW_BARS=3
# Equal-highs/lows tolerance in ATR units (highs within tol×ATR are clustered as one pool)
# FORGE_ICT_LIQUIDITY_EQUAL_TOLERANCE_ATR_MULT=0.2
# Sweep-rejection wick floor in ATR units (wick/ATR ratio required for a valid sweep)
# FORGE_ICT_LIQUIDITY_REJECTION_MIN_WICK_ATR_MULT=0.3

# ─────────────────────────────────────────────────────────────────────────────
# v2.7.123 — Phase A ICT atoms (compute + log only, Mode A — zero trade impact)
# Five new atoms behind individual enable flags. Per docs/FORGE_SETUP_ICT_MAP.md §B.8.2.
# Enable individually to populate SIGNALS columns. Composite scoring (Phase B) reads these.
# Atom function bodies live in ea/include/Forge/IctScoring.mqh + IctStructure.mqh.
# ─────────────────────────────────────────────────────────────────────────────
# Atom 1 — kill-zone matches category-favored window (MSS_CONT: LO+NY_AM; OTE: any KZ;
#   LIQ_SWEEP_REV: LO+LC; BREAKER: any KZ)
# FORGE_ICT_ATOM_KILLZONE_FAVORABLE_ENABLED=0
# Atom 2 — trade direction aligns with HTF bias (htf_label BULL/BEAR or h1_trend ±0.5)
# FORGE_ICT_ATOM_HTF_ALIGNED_ENABLED=0
# Atom 3 — current price inside the 62-79% fib OTE band of the most recent confirmed swing pair
# FORGE_ICT_ATOM_PULLBACK_IN_OTE_ENABLED=0
# Atom 4 — current price on the correct side of the dealing-range midpoint (discount for BUY, premium for SELL)
# FORGE_ICT_ATOM_PREMIUM_DISCOUNT_ALIGNED_ENABLED=0
# Atom 5 — active FVG aligned with the direction contains current price (LIQ_SWEEP_REV reversal leg)
# FORGE_ICT_ATOM_FVG_ON_REVERSAL_LEG_ENABLED=0

# ─────────────────────────────────────────────────────────────────────────────
# v2.7.124 Phase B — ICT composite scoring (Mode A, log only)
# Each composite returns 0-10 weighted sum of atoms per category per direction
# (3 categories × 2 directions = 6 score columns). BREAKER_RETEST deferred
# until Phase 3 IctOrderBlock.mqh ships. Per docs/FORGE_SETUP_ICT_MAP.md §B.8.2.
# ─────────────────────────────────────────────────────────────────────────────
# FORGE_COMPOSITE_MSS_CONT_SCORE_ENABLED=0
# FORGE_COMPOSITE_OTE_RETRACE_SCORE_ENABLED=0
# FORGE_COMPOSITE_LIQ_SWEEP_REV_SCORE_ENABLED=0

# CVCSM = Conditional Cooldown State Machine. Per-direction OPEN/COOLDOWN/RETRYING.
# SL-only trigger (not TP). Retries on every M5 close with PEMCG re-evaluation.
# FORGE_GATE_CVCSM_ENABLED=1
# FORGE_GATE_CVCSM_RELEASE_THRESHOLD=2          # <=N PEMCG warnings = OK to retry
# FORGE_TIMING_CVCSM_REQUIRED_CLEAN_BARS=2      # N consecutive clean bars to release
# FORGE_TIMING_CVCSM_MAX_COOLDOWN_SEC=1800      # safety hard timeout (30 min)
# FORGE_GATE_CVCSM_TRIGGER_ON_SL=1
# FORGE_GATE_CVCSM_TRIGGER_ON_REGIME_FLIP=1
# BB_EXHAUSTION_REVERSAL = Layer 3, counter-trade capture when UMCG blocks opposite side.
# FORGE_SETUP_BB_EXHAUSTION_REVERSAL_ENABLED=1
# FORGE_GATE_BB_EXHAUSTION_REVERSAL_MIN_WARNINGS=4   # PEMCG warnings to trigger reversal
# FORGE_GEOMETRY_BB_EXHAUSTION_REVERSAL_LOT=0.10
# FORGE_GEOMETRY_BB_EXHAUSTION_REVERSAL_SL_ATR_MULT=1.0
# FORGE_GEOMETRY_BB_EXHAUSTION_REVERSAL_TP1_ATR_MULT=0.0
# FORGE_GEOMETRY_BB_EXHAUSTION_REVERSAL_TP2_ATR_MULT=0.0
# FORGE_TIMING_BB_EXHAUSTION_REVERSAL_COOLDOWN_SEC=1800
# FORGE_GATE_BB_EXHAUSTION_REVERSAL_PROXIMITY_ATR=1.5
# v2.7.89 — Conviction-tier amplifier + legs for BB_EXHAUSTION_REVERSAL (counter-trade at UMCG block).
# Wires bb_exhaustion_reversal_lot into actual order placement (was logged-only pre-v2.7.89).
# Two tiers based on PEMCG warning count at fire-time:
#   BASE tier (>= min_warnings, default 4): legs=1, lot = base_lot × lot_amplifier
#   HIGH tier (>= high_conviction_warnings): legs=legs_high_conviction, lot = base_lot × amp × HIGH factor
# FORGE_GEOMETRY_BB_EXHAUSTION_REVERSAL_LOT_AMPLIFIER=1.0          # constant lot multiplier (BASE tier)
# FORGE_GATE_BB_EXHAUSTION_REVERSAL_HIGH_CONVICTION_WARNINGS=6     # PEMCG threshold for HIGH tier
# FORGE_GEOMETRY_BB_EXHAUSTION_REVERSAL_HIGH_CONVICTION_LOT_FACTOR=2.0  # HIGH tier doubles base × amp
# FORGE_GEOMETRY_BB_EXHAUSTION_REVERSAL_LEGS_HIGH_CONVICTION=3     # leg count at HIGH tier (BASE=1)
# v2.7.92 — ADX gate (don't counter-trade in strong trends). Block Layer 3 when M5 ADX >= this.
# Wilder + canonical literature: reversals form on FALLING ADX, not on rising ADX > 30-35.
# Run 6 evidence: 2 BB_EXHAUSTION_REVERSAL_SELLs at ADX 41.6 lost ~$1,260 to a continuing thrust.
# Set to 0 to disable.
# FORGE_GATE_BB_EXHAUSTION_REVERSAL_MAX_ADX=35.0
# v2.7.94 — Wide-Range Bar gate. Block counter-trade after a capitulation/spike M5 bar.
# Apr 2 04:10 reversal BUY fired after a 41-pt bar (4.3xATR) → -$2,897 loss. Default 2.0 = require
# prev bar <= 2x ATR before reversal can fire. Industry: don't catch the falling knife.
# FORGE_GATE_BB_EXHAUSTION_REVERSAL_MAX_PREV_BAR_RANGE_ATR_MULT=2.0
# v2.7.93 — Anti-retest gate for BB_BREAKOUT. Require price actually cleared the band at entry.
# Run 7 G5006 evidence: prev_close above BB triggered the setup, but entry tick was 0.47 ATR
# BELOW BB upper (retest from below = failed breakout). G5005 winner had +0.527 ATR above BB.
# Default 0.1 separates the winner from the loser cleanly. Set to 0 to disable.
# FORGE_GATE_BB_BREAKOUT_MIN_BREAKOUT_ATR_MULT=0.1
# FORGE_GATE_BB_BREAKOUT_MIN_BREAKDOWN_ATR_MULT=0.1

# ── v2.7.85 — TC_BUY/SELL Setup #14 (Momentum) recalibration ──
# Apr 6 17:35 TC_BUY -$720.38 loss had h1_trend=0.27 (weak HTF) and dist_from_day_high=1.21*ATR.
# Stricter h1 + day-extreme distance gates separate loser from winner (h1=1.22, dist=8.86).
# FORGE_GATE_TREND_CONTINUATION_BUY_H1_MIN=1.0
# FORGE_GATE_TREND_CONTINUATION_SELL_H1_MAX=1.0
# FORGE_GATE_TREND_CONTINUATION_BUY_MAX_DIST_FROM_DAY_HIGH_ATR=3.0
# FORGE_GATE_TREND_CONTINUATION_SELL_MAX_DIST_FROM_DAY_LOW_ATR=3.0

# ── Backfill — sync-mapped knobs that lacked .env.example documentation ──
# Restored 2026-05-14 to satisfy /forge-ea-review Mandatory Check C (sync ↔ .env.example parity).
# All keys below are mapped in scripts/sync_scalper_config_from_env.py and ACTIVE in .env.

# BREAKOUT_BUY_SCORE velocity guard — block low-score breakouts on stalling velocity.
# FORGE_GATE_BREAKOUT_BUY_SCORE_VELOCITY_CHECK_ENABLED=1
# FORGE_GATE_BREAKOUT_BUY_SCORE_VELOCITY_THRESHOLD=-5      # block if signed 5-bar velocity below this

# BB_PULLBACK_BUY velocity guard — block pullback BUY when velocity is falling.
# FORGE_GATE_BB_PULLBACK_BUY_BLOCK_ON_FALLING_VELOCITY=1
# FORGE_GATE_BB_PULLBACK_BUY_MIN_VELOCITY_5BAR_SIGNED=-1.0  # min signed 5-bar velocity to allow entry

# CONVICTION_DECAY — partial-close staging when post-entry conviction drops.
# L1/L2/L3 ratios are conviction-score fractions (vs entry); L1/L2 close % of remaining position.
# FORGE_SETUP_CONVICTION_DECAY_PARTIAL_CLOSE_ENABLED=1
# FORGE_GATE_CONVICTION_DECAY_L1_RATIO=0.75       # first decay tier (25% conviction loss)
# FORGE_GATE_CONVICTION_DECAY_L2_RATIO=0.50       # second decay tier (50% loss)
# FORGE_GATE_CONVICTION_DECAY_L3_RATIO=0.25       # third decay tier (75% loss = full close)
# FORGE_GEOMETRY_CONVICTION_DECAY_L1_CLOSE_PCT=25 # close 25% of remaining at L1
# FORGE_GEOMETRY_CONVICTION_DECAY_L2_CLOSE_PCT=50 # close 50% of remaining at L2
# FORGE_TIMING_CONVICTION_DECAY_GRACE_BARS=2      # bars after entry before decay can trigger

# REVERSE_SELL_IN_BULL — counter-trade SELL setup inside a confirmed bull regime.
# Requires very high RSI + VWAP-distance + positive H1 trend + DI+>DI- (true exhaustion).
# FORGE_SETUP_REVERSE_SELL_IN_BULL_ENABLED=1
# FORGE_GEOMETRY_REVERSE_SELL_IN_BULL_LOT_FACTOR=0.5
# FORGE_GATE_REVERSE_SELL_IN_BULL_MIN_RSI=72.0
# FORGE_GATE_REVERSE_SELL_IN_BULL_MIN_VWAP_DIST_ATR=2.0
# FORGE_GATE_REVERSE_SELL_IN_BULL_MIN_H1_TREND=1.0
# FORGE_GATE_REVERSE_SELL_IN_BULL_REQUIRE_DI_PLUS_ABOVE_MINUS=1
# FORGE_GEOMETRY_REVERSE_SELL_IN_BULL_SL_ATR_MULT=2.0
# FORGE_GEOMETRY_REVERSE_SELL_IN_BULL_TP1_ATR_MULT=1.0
# FORGE_GEOMETRY_REVERSE_SELL_IN_BULL_TP2_ATR_MULT=2.0
# FORGE_TIMING_REVERSE_SELL_IN_BULL_COOLDOWN_SEC=300

# GRINDING_SELL — slow downward grind setup (chop-with-drift). RSI 30-55 band + min velocity + room.
# FORGE_SETUP_GRINDING_SELL_ENABLED=1
# FORGE_GEOMETRY_GRINDING_SELL_LOT_FACTOR=0.5
# FORGE_GATE_GRINDING_SELL_MIN_VELOCITY=0.5       # min |signed velocity| for "grind" qualification
# FORGE_GATE_GRINDING_SELL_MAX_RSI=55.0           # upper RSI bound for grind regime
# FORGE_GATE_GRINDING_SELL_MIN_RSI=30.0           # lower RSI bound (below = oversold, not grind)
# FORGE_GATE_GRINDING_SELL_ROOM_MIN_ATR=0.3       # min distance-to-next-support, in ATR
# FORGE_GEOMETRY_GRINDING_SELL_SL_ATR_MULT=2.5
# FORGE_GEOMETRY_GRINDING_SELL_TP1_ATR_MULT=0.7
# FORGE_GEOMETRY_GRINDING_SELL_TP2_ATR_MULT=1.5
# FORGE_TIMING_GRINDING_SELL_COOLDOWN_SEC=600
