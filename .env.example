# ──────────────────────────────────────────────
# SIGNAL SYSTEM v1.1.0 — Environment Configuration
# Copy to .env and fill in your values
# Lines starting with # are comments; uncomment to override defaults.
# ──────────────────────────────────────────────

# ── Claude API ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# Service installer override: force a specific python interpreter for launchd/systemd
# SIGNAL_PYTHON=/absolute/path/to/python

# ── Telegram (Telethon — user account for reading signal channels) ──
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# ── Telegram channels to monitor (comma-separated channel IDs or usernames) ──
# Get channel ID by forwarding a message from the channel to @userinfobot
TELEGRAM_CHANNELS=-1001234567890,-1009876543210
# Optional priority execution allowlist (channel titles and/or chat IDs; comma-separated).
# If unset/empty, all monitored rooms can dispatch in SIGNAL/HYBRID.
# Prefer chat IDs to avoid title-rename drift. Both vars are supported and merged.
# SIGNAL_TRADE_ROOMS=-1001234567890,-1009876543210
# ACTIVE_SIGNAL_TRADE_ROOMS=-1001234567890,-1009876543210

# ── Telegram Bot (for HERALD notifications and AURUM responses) ───
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff
TELEGRAM_CHAT_ID=987654321

# ══════════════════════════════════════════════════════════════════════
# MT5 FILE BUS
# ══════════════════════════════════════════════════════════════════════
# These paths must be the SAME folder FORGE.mq5 uses (Terminal → Common → Files).
# Best: symlink repo MT5/ → Common/Files (see docs/FORGE_BRIDGE.md).
# Otherwise use absolute paths below.
MT5_MARKET_FILE=MT5/market_data.json
MT5_CMD_FILE=MT5/command.json
MT5_CONFIG_FILE=MT5/config.json
MT5_MODE_FILE=MT5/mode_status.json
MT5_BROKER_FILE=MT5/broker_info.json
# Optional mirror: write command.json to a second path (for symlink mismatches).
# Leave blank to disable. See docs/FORGE_BRIDGE.md.
# MT5_CMD_FILE_MIRROR=

# macOS MT5 native app absolute paths (alternative to symlink):
# MT5_CMD_FILE=/Users/YOU/Library/Application Support/MetaQuotes/Terminal/Common/Files/command.json
# MT5_MARKET_FILE=/Users/YOU/Library/Application Support/MetaQuotes/Terminal/Common/Files/market_data.json

# ── FORGE magic number ──────────────────────────
# Must match ea/FORGE.mq5 input MagicNumber. Group magic = base + group_id.
# FORGE_MAGIC_NUMBER=202401

# ══════════════════════════════════════════════════════════════════════
# TRADINGVIEW MCP (LENS)
# ══════════════════════════════════════════════════════════════════════
LENS_MCP_CMD=npx tradingview-mcp-jackson
LENS_SYMBOL=XAUUSD
LENS_EXCHANGE=FX_IDC
LENS_TIMEFRAMES=5m,1h
# In-memory cache; keep ≤ BRIDGE_LENS_SEC unless callers need longer TTL
LENS_CACHE_SEC=60
# Refresh TradingView MCP while BRIDGE is in WATCH (seconds; 0 = disable)
LENS_WATCH_REFRESH_SEC=60
LENS_BBW_SQUEEZE=0.035
# Include TradingView textual brief payload in lens snapshots (true/false)
# LENS_ENABLE_TV_BRIEF=true
# TradingView brief refresh interval in seconds
# LENS_TV_BRIEF_INTERVAL_SEC=1800
# Conflict detection: LENS vs MT5 data thresholds
# LENS_MAX_RSI_DIFF=15.0
# LENS_MAX_PRICE_DIFF=5.0

# ══════════════════════════════════════════════════════════════════════
# TRADING PARAMETERS
# ══════════════════════════════════════════════════════════════════════
DEFAULT_MODE=SIGNAL
# Restore previous mode from status.json on BRIDGE restart (true/false)
# RESTORE_MODE_ON_RESTART=true

# ── TP management ──────────────────────────────
TP1_CLOSE_PCT=70
TP2_CLOSE_PCT=20
MOVE_BE_ON_TP1=true

# ── SIGNAL mode ────────────────────────────────
# Lot size and trade count for Telegram signal-sourced entries
# SIGNAL_LOT_SIZE=0.01
# SIGNAL_NUM_TRADES=4
# Reject signals older than this (seconds); scalping signals must be fresh
# SIGNAL_EXPIRY_SEC=60
# ── Regime engine / entry policy rollout ───────
# Master toggle for inference snapshots (HMM primary, Gaussian fallback).
# REGIME_ENGINE_ENABLED=true
# Rollout mode for SIGNAL/AURUM entry placement:
#   off    = legacy endpoint bias only
#   shadow = compute/log regime policy but execute legacy ladder
#   active = apply regime-conditioned ladder when confidence + freshness pass
# REGIME_ENTRY_MODE=off
# Minimum posterior confidence required for active policy application (0-1)
# REGIME_MIN_CONFIDENCE=0.60
# Snapshot freshness gate in seconds (older snapshots are marked stale and blocked in active mode)
# REGIME_STALE_SEC=180
# Retrain interval for HMM model (seconds)
# REGIME_RETRAIN_INTERVAL_SEC=3600
# Minimum feature samples before HMM training is attempted
# REGIME_MIN_TRAIN_SAMPLES=120
# Regime snapshot persistence cadence to SCRIBE (seconds; transitions are always emitted immediately)
# REGIME_LOG_INTERVAL_SEC=30

# ── AUTO_SCALPER mode ──────────────────────────
# AURUM-driven autonomous scalping parameters
# AUTO_SCALPER_LOT_SIZE=0.01
# AUTO_SCALPER_NUM_TRADES=4
# AUTO_SCALPER_POLL_INTERVAL=120
# AUTO_SCALPER_MAX_GROUPS=2
# Native FORGE scalper mode passed through BRIDGE -> MT5 config.json (NONE|AUTO|MANUAL by EA contract)
# FORGE_SCALPER_MODE=NONE

# ── Pending order management ───────────────────
# Auto-cancel fulfilled-pending MT5 orders that have not triggered after this many seconds (0 = disable)
# PENDING_ORDER_TIMEOUT_SEC=3600

# ══════════════════════════════════════════════════════════════════════
# AEGIS (risk guard)
# ══════════════════════════════════════════════════════════════════════
AEGIS_RISK_PCT=2.0
AEGIS_MAX_RISK_PCT=5.0
AEGIS_NUM_TRADES=8
AEGIS_MAX_SLIPPAGE=20.0
AEGIS_MIN_RR=1.2
AEGIS_MAX_DAILY_LOSS=5.0
AEGIS_MAX_OPEN_GROUPS=3
AEGIS_MAX_LOT_TOTAL=5.0

# Lot sizing mode: "fixed" = use source lot_per_trade as-is, "risk_based" = compute from balance/risk%
# AEGIS_LOT_MODE=fixed
# Minimum lot size (broker minimum for XAUUSD)
# AEGIS_MIN_LOT=0.01
# Minimum SL distance in pips (reject signals with tighter stops)
# AEGIS_MIN_SL_PIPS=3.0
# XAUUSD pip value per standard lot ($100/pip for 1.0 lot)
# AEGIS_PIP_VALUE_PER_LOT=100.0
# SIGNAL-source overrides (for room signals only; falls back to base AEGIS_* when unset)
# AEGIS_SIGNAL_MIN_RR=0.8
# AEGIS_SIGNAL_MIN_SL_PIPS=2.0
# AEGIS_SIGNAL_MAX_SLIPPAGE=25.0
# SIGNAL limit-orientation gate for LISTENER room entries (applies in SIGNAL and HYBRID):
#   both (default) = enforce BUY below market and SELL above market
#   buy            = enforce BUY only
#   sell           = enforce SELL only
#   off            = disable orientation gate (allow both BUY/SELL through remaining guards)
# AEGIS_SIGNAL_LIMIT_ORIENTATION=both

# ── AEGIS multi-TF trend filter ────────────────
# Enable H1/M15/M5 trend cascade (true/false)
# AEGIS_H1_TREND_FILTER=true
# EMA20 vs EMA50 diff threshold for FLAT classification ($)
# AEGIS_H1_FLAT_THRESHOLD=1.0

# ── AEGIS lot scaling ──────────────────────────
AEGIS_SCALE_DOWN_LOSSES=3        # Reduce lots after N consecutive losses
AEGIS_SCALE_UP_WINS=3            # Increase lots after N consecutive wins
AEGIS_SCALE_DOWN_FACTOR=0.5      # Half lots when scaling down

# ── AEGIS trading-day boundary ─────────────────
# Daily loss limit / session P&L rolls at this UTC hour.
# If unset, uses SESSION_LONDON_START (same as kill-zone London open).
# AEGIS_SESSION_RESET_HOUR=8

# ══════════════════════════════════════════════════════════════════════
# DRAWDOWN PROTECTION
# ══════════════════════════════════════════════════════════════════════
# Equity DD circuit breaker: close all + force WATCH if equity drops this % from session peak
# DD_EQUITY_CLOSE_ALL_PCT=3.0
# Block new groups if floating loss exceeds this % of balance
# DD_FLOATING_BLOCK_PCT=2.0
# Seconds to wait after a group closes at loss before AUTO_SCALPER resumes
# DD_LOSS_COOLDOWN_SEC=300

# ══════════════════════════════════════════════════════════════════════
# SENTINEL (news guard + RSS)
# See docs/SENTINEL.md
# ══════════════════════════════════════════════════════════════════════
SENTINEL_GUARD_MIN=30
SENTINEL_POLL_SEC=60

# Post-event guard windows (minutes after scheduled start time):
#   Instant events (NFP, CPI, etc.): short settle window
#   Extended events (speeches, FOMC, press conferences): holds through duration
# SENTINEL_POST_GUARD_MIN=5
# SENTINEL_EXTENDED_GUARD_MIN=60

# Sentinel override: duration (seconds) when user manually bypasses guard
# SENTINEL_OVERRIDE_DURATION_SEC=600

# ForexFactory calendar: which currency columns count (comma-separated).
# USD-only: SENTINEL_CALENDAR_CURRENCIES=USD
SENTINEL_CALENDAR_CURRENCIES=USD,EUR,GBP,JPY,AUD,NZD,CAD,CHF

# Periodic event digest interval (seconds); adapts: 10min near event, 30min normally
# SENTINEL_DIGEST_INTERVAL_SEC=600
# Master toggle for RSS/news enrichment in SENTINEL (1=enabled, 0=disable all feeds)
# SENTINEL_ENABLE_NEWS_FEEDS=1

# Free RSS headlines: FXStreet + Google News + Investing.com + optional DailyFX
# Disable all: SENTINEL_ENABLE_NEWS_FEEDS=0
# SENTINEL_ENABLE_FXSTREET_RSS=1
# SENTINEL_FXSTREET_RSS=https://www.fxstreet.com/rss/news
# SENTINEL_ENABLE_GOOGLE_NEWS=1
# SENTINEL_GOOGLE_NEWS_QUERY=forex OR XAUUSD OR gold OR ECB OR BOJ OR FOMC OR CPI NFP
# SENTINEL_ENABLE_INVESTING_RSS=1
# DailyFX often 403 from cloud IPs — default off; try at home:
# SENTINEL_ENABLE_DAILYFX_RSS=0
# Your own RSS feeds (comma-separated, max 6):
# SENTINEL_EXTRA_RSS_URLS=
# SENTINEL_RSS_MAX_PER_FEED=8
# SENTINEL_RSS_TOTAL_CAP=40
# SENTINEL_RSS_TIMEOUT=12

# ══════════════════════════════════════════════════════════════════════
# BRIDGE (orchestrator)
# ══════════════════════════════════════════════════════════════════════
BRIDGE_LOOP_SEC=5
# How often to call TradingView MCP (each call is heavy); 30–120s typical
BRIDGE_LENS_SEC=60
BRIDGE_SENTINEL_SEC=60
BRIDGE_MT5_STALE=120
# Optional relaxed stale threshold used only when market_data.json read/parse
# briefly fails (transient file-write race). Must be >= BRIDGE_MT5_STALE.
# BRIDGE_MT5_STALE_RELAXED=180
# Consecutive market_data read/parse failures required before stale fallback
# can trip circuit breaker (default 2).
# BRIDGE_MT5_READ_FAIL_STREAK=2
# Optional mode lock to prevent drift (e.g., keep SIGNAL/HYBRID pinned)
# BRIDGE_PIN_MODE=HYBRID
# AURUM_EXEC HTTP bridge target (used by BRIDGE action AURUM_EXEC)
# AURUM_EXEC_BASE_URL=http://127.0.0.1:7842
# AURUM_EXEC_TIMEOUT_SEC=15
# Telegram result message cap for AEB action feedback
# AEB_TELEGRAM_MAX_CHARS=3000

# ── AEB (AURUM Execution Bridge) guardrails ───────────────────────
# SCRIBE_QUERY limits
# AEB_SCRIBE_MAX_ROWS=500
# AEB_SCRIBE_BUSY_MS=5000
# AEB_SCRIBE_TIMEOUT_SEC=10
# SHELL_EXEC allowlist + limits
# AEB_SHELL_EXEC_ALLOWED_PROGRAMS=python3,sqlite3
# AEB_SHELL_EXEC_ALLOWED_PATH_PREFIXES=scripts/,data/,logs/
# Block SHELL_EXEC when command origin_source matches these values (comma-separated)
# AEB_SHELL_EXEC_BLOCKED_SOURCES=TELEGRAM
# AEB_SHELL_EXEC_TIMEOUT_SEC=30
# AEB_SHELL_EXEC_MAX_OUTPUT_CHARS=4000

# ══════════════════════════════════════════════════════════════════════
# RECONCILER
# ══════════════════════════════════════════════════════════════════════
RECON_INTERVAL_SEC=3600          # Run reconciliation every hour
RECON_PNL_TOLERANCE=1.0          # Ignore P&L differences below this $
# Auto-close SCRIBE groups with no MT5 exposure (true/false)
# RECON_CLOSE_STALE_GROUPS=true

# ══════════════════════════════════════════════════════════════════════
# AURUM (AI agent)
# ══════════════════════════════════════════════════════════════════════
AURUM_MODEL=claude-sonnet-4-20250514
AURUM_MAX_TOKENS=1000
# Conversation turns retained per source (user+assistant pairs) for context/token control
# AURUM_MAX_CONV_TURNS=10
SOUL_FILE=SOUL.md
SKILL_FILE=SKILL.md

# ══════════════════════════════════════════════════════════════════════
# WEB SEARCH (Google News RSS — free, no API key)
# Used by AURUM for live event queries ("is trump still speaking?").
# Also exposed via ATHENA GET /api/search?q=...
# ══════════════════════════════════════════════════════════════════════
# WEB_SEARCH_CACHE_SEC=120
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT=8

# ══════════════════════════════════════════════════════════════════════
# ATHENA (dashboard + API)
# ══════════════════════════════════════════════════════════════════════
ATHENA_PORT=7842
DASHBOARD_DIR=dashboard
# Optional — POST /api/scribe/query: shared secret for auth
#   Authorization: Bearer <secret>  OR  header X-ATHENA-SCRIBE-TOKEN: <secret>
# Leave unset for typical local-only use (no auth on that endpoint).
# ATHENA_SCRIBE_QUERY_SECRET=
# SCRIBE_QUERY_MAX_ROWS=500
# SCRIBE_QUERY_BUSY_MS=5000
# Optional shared secret for POST /api/aurum/exec (same token BRIDGE uses for AURUM_EXEC)
# ATHENA_AURUM_EXEC_SECRET=

# Mirror each component heartbeat to Flask HTTP (non-blocking):
# COMPONENT_HEARTBEAT_USE_HTTP=1
# ATHENA_INTERNAL_BASE=http://127.0.0.1:7842

# ══════════════════════════════════════════════════════════════════════
# SCRIBE (database)
# ══════════════════════════════════════════════════════════════════════
SCRIBE_DB=data/aurum_intelligence.db
# NDJSON audit mirror for system_events (set 0 to disable)
# SCRIBE_AUDIT_ENABLE=1
# SCRIBE_AUDIT_JSONL=logs/audit/system_events.jsonl

# ══════════════════════════════════════════════════════════════════════
# LISTENER
# ══════════════════════════════════════════════════════════════════════
# Channel message cache refresh for ATHENA API (seconds)
# LISTENER_CACHE_REFRESH_SEC=300
# Idle heartbeat interval for component grid (seconds)
# LISTENER_HEARTBEAT_SEC=120
# WARN if no messages ingested for this many seconds
# LISTENER_STALE_THRESHOLD_SEC=600
# Send chart-analysis summary to Telegram bot chat for signal-room media uploads
# LISTENER_SIGNAL_MEDIA_SUMMARY_TO_BOT=true
# Persist signal-room uploads for replay/back-analysis
# LISTENER_SIGNAL_MEDIA_ARCHIVE_ENABLED=true
# LISTENER_SIGNAL_MEDIA_ARCHIVE_DIR=data/signal_media_archive

# ══════════════════════════════════════════════════════════════════════
# VISION (image extraction for LISTENER + AURUM)
# ══════════════════════════════════════════════════════════════════════
# Enable image extraction pipeline (true/false)
# VISION_ENABLED=true
# Max inbound image size accepted for processing (MB)
# VISION_MAX_IMAGE_MB=8
# Hold image-origin signals automatically when confidence is LOW
# VISION_LOW_CONFIDENCE_HOLD=true
# Optional model override for vision extraction
# VISION_MODEL=claude-sonnet-4-6
# Max image edge (px) before downscaling for Claude vision latency/clarity balance
# VISION_MAX_EDGE_PX=1568
# Run second focused pass on right-side price axis when first pass is LOW/empty
# VISION_SECOND_PASS=true
# Optional OCR numeric-hint fallback (requires opencv + pytesseract + local tesseract binary)
# VISION_OCR_FALLBACK=true

# ══════════════════════════════════════════════════════════════════════
# SESSION BOUNDARIES (UTC hours — XAUUSD kill zones)
# ══════════════════════════════════════════════════════════════════════
# ASIAN wraps midnight when START > END (e.g. 22–08 UTC = Tokyo/Sydney into London).
# Flat range when START < END (e.g. 1–8 = main Tokyo hours only).
SESSION_ASIAN_START=22
SESSION_ASIAN_END=8
# London/NY windows below are local-market-hour based (DST-aware).
SESSION_LONDON_TZ=Europe/London
SESSION_LONDON_LOCAL_START=8
SESSION_LONDON_LOCAL_END=13
SESSION_NY_TZ=America/New_York
SESSION_LONDON_NY_LOCAL_START=8
SESSION_LONDON_NY_LOCAL_END=12
SESSION_NY_LOCAL_START=12
SESSION_NY_LOCAL_END=17
# Legacy UTC fields kept for backward compatibility / older tools.
SESSION_LONDON_START=8
SESSION_LONDON_END=13
SESSION_LONDON_NY_START=13
SESSION_LONDON_NY_END=17
SESSION_NY_START=17
SESSION_NY_END=22
# Sydney kill-zone uses local market time (DST-aware via SESSION_SYDNEY_TZ).
# Default local 09:00–17:00 maps to ~22:00–06:00 UTC (summer) or 23:00–07:00 UTC (winter).
SESSION_SYDNEY_TZ=Australia/Sydney
SESSION_SYDNEY_LOCAL_START=9
SESSION_SYDNEY_LOCAL_END=17
# Daily Sydney-open reminder (once per Sydney local date)
SYDNEY_OPEN_ALERT_ENABLED=true
SYDNEY_OPEN_ALERT_GRACE_MIN=5

# ══════════════════════════════════════════════════════════════════════
# INTERNAL CONFIG FILE PATHS
# These rarely need changing — defaults are relative to python/ CWD.
# ══════════════════════════════════════════════════════════════════════
# BRIDGE_STATUS_FILE=config/status.json
# SENTINEL_STATUS_FILE=config/sentinel_status.json
# Legacy alias still accepted by sentinel.py:
# SENTINEL_STATUS=config/sentinel_status.json
# LENS_SNAPSHOT_FILE=config/lens_snapshot.json
# Legacy alias still accepted by lens.py:
# LENS_SNAPSHOT=config/lens_snapshot.json
# AURUM_CMD_FILE=config/aurum_cmd.json
# LISTENER_SIGNAL_FILE=config/parsed_signal.json
# LISTENER_MGMT_FILE=config/management_cmd.json
# LENS_BRIEF_FILE=config/lens_brief.json
# SCALPER_ENTRY_FILE=MT5/scalper_entry.json
# TELEGRAM_SESSION_FILE=config/aurum_session   # aurum only; listener session is fixed at config/telegram_session

# ═══════════════════════════════════════════════════════════════════
# DEFERRED ANALYSIS RUNS (analysis_runner.py)
# AEB ANALYSIS_RUN action queues async analyses; results post to the
# existing Telegram channel via Herald (BOT_TOKEN / CHAT_ID above).
# ═══════════════════════════════════════════════════════════════════
# Directory for per-query result + status files. Default: <repo>/logs/analysis
# ANALYSIS_LOG_DIR=
# Max concurrent analysis worker threads. Default: 4 (clamped 1–32)
# ANALYSIS_MAX_CONCURRENCY=4
