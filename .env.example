# FORGE_GATE_TREND_CONTINUATION_BUY_REQUIRE_ABOVE_VWAP=1      # block when price < vwap_price
# FORGE_GATE_TREND_CONTINUATION_BUY_MAX_POC_DISTANCE_ATR=1.5  # block when |price-poc| > this×ATR (0=off)
# FORGE_GATE_TREND_CONTINUATION_BUY_BLOCK_BEARISH_DIV=1       # block when g_rsi_div_type in (REG_BEAR, HID_BEAR)
# FORGE_GATE_TREND_CONTINUATION_BUY_REQUIRE_H4_ALIGNMENT=1    # require h4_trend_strength >= h4_min
# FORGE_GATE_TREND_CONTINUATION_BUY_H4_MIN=0.0                # H4 trend floor (non-negative)

