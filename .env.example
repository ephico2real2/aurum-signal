# ── v2.7.67 — TC velocity / DI / day-extreme atoms ──
# Uses the v2.7.65 velocity globals. Default-ON. Blocks dying-trend entries.
# Live state demo: ADX delta −8.91 (dying trend) would correctly block a counter-trend BUY here.
# FORGE_GATE_TREND_CONTINUATION_REQUIRE_VELOCITY_CHECK=1            # master toggle
# FORGE_GATE_TREND_CONTINUATION_MIN_ADX_DELTA_5BAR=0.0              # ADX rising required (5-bar delta > 0)
# FORGE_GATE_TREND_CONTINUATION_MIN_VELOCITY_5BAR=0.5               # ≥0.5×ATR move in last 25min
# FORGE_GATE_TREND_CONTINUATION_BUY_MIN_MACD_SLOPE_5BAR=0.2         # BUY: macd slope > +0.2 (strengthening up)
# FORGE_GATE_TREND_CONTINUATION_SELL_MAX_MACD_SLOPE_5BAR=-0.2       # SELL: macd slope < −0.2 (strengthening down)
# FORGE_GATE_TREND_CONTINUATION_BUY_MIN_DI_BALANCE=0.0              # BUY: h1 DI+ > DI-
# FORGE_GATE_TREND_CONTINUATION_SELL_MAX_DI_BALANCE=0.0             # SELL: h1 DI+ < DI-
# FORGE_GATE_TREND_CONTINUATION_BUY_MAX_DIST_FROM_DAY_HIGH_ATR=0.5  # BUY: not at day-high
# FORGE_GATE_TREND_CONTINUATION_SELL_MAX_DIST_FROM_DAY_LOW_ATR=0.5  # SELL: not at day-low

# ── v2.7.59 — BB_LOWER_REVERSION_BUY falling-knife protection (Apr 2 -$386 fix) ──
# Apr 2 G5021-G5024 fired BLR_BUY 4 times in 38min on a crash (RSI 35→24→21→19).
# These guards block the cascade-failure pattern.
# FORGE_GATE_BB_LOWER_REVERSION_BUY_REQUIRE_REVERSAL_CANDLE=1  # require last M5 close > open
# FORGE_GATE_BB_LOWER_REVERSION_BUY_CONSEC_LOSS_MAX=2          # N SLs trigger throttle
# FORGE_TIMING_BB_LOWER_REVERSION_BUY_CONSEC_LOSS_WINDOW_SEC=1800   # SL counter window (30min)
# FORGE_TIMING_BB_LOWER_REVERSION_BUY_CONSEC_LOSS_COOLDOWN_SEC=1800 # throttle duration (30min)
# FORGE_GATE_BB_LOWER_REVERSION_BUY_H4_MIN=-1.0                # block when h4_trend ≤ this (strongly bearish HTF)

# ── v2.7.59 — MOMENTUM_DUMP cascade enable (gate the v2.7.28 hardcoded skip) ──
# Was: FORGE.mq5:11570 returned early for MD groups. Now gated; v2.7.56 multi-leg supersedes.
