{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signal-system.local/schemas/files/market_data.schema.json",
  "title": "MT5/market_data.json",
  "description": "FORGE writes; BRIDGE/ATHENA read. Partial schema — FORGE may add fields.",
  "type": "object",
  "required": ["timestamp_unix"],
  "properties": {
    "timestamp_unix": { "type": "number" },
    "timestamp_utc": { "type": "string" },
    "symbol": { "type": "string" },
    "session": { "type": "string" },
    "price": {
      "type": "object",
      "properties": {
        "bid": { "type": "number" },
        "ask": { "type": "number" },
        "spread": { "type": "number" }
      },
      "additionalProperties": true
    },
    "account": {
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "session_pnl": { "type": "number" },
        "open_positions_count": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "open_positions": { "type": "array" },
    "indicators_h1": { "type": "object" }
  },
  "additionalProperties": true
}
