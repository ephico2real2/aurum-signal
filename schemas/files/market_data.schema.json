{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signal-system.local/schemas/files/market_data.schema.json",
  "title": "MT5/market_data.json",
  "description": "FORGE writes; BRIDGE/ATHENA read. Partial schema — FORGE may add fields.",
  "type": "object",
  "required": ["timestamp_unix"],
  "properties": {
    "timestamp_unix": { "type": "number" },
    "timestamp_utc": { "type": "string" },
    "symbol": { "type": "string" },
    "session": { "type": "string" },
    "price": {
      "type": "object",
      "properties": {
        "bid": { "type": "number" },
        "ask": { "type": "number" },
        "spread": { "type": "number" }
      },
      "additionalProperties": true
    },
    "account": {
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "session_pnl": { "type": "number" },
        "open_positions_count": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "open_positions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ticket": { "type": "integer" },
          "symbol": { "type": "string" },
          "type": { "type": "string" },
          "lots": { "type": "number" },
          "open_price": { "type": "number" },
          "current_price": { "type": "number" },
          "sl": { "type": "number" },
          "tp": { "type": "number" },
          "profit": { "type": "number" },
          "magic": { "type": "integer" },
          "forge_managed": { "type": "boolean" },
          "comment": {
            "type": "string",
            "description": "FORGE per-leg metadata grammar: 'FORGE|G<id>|<leg_index>|TP<stage>'. BRIDGE parses |TP<n> to backfill trade_positions.tp_stage on fill."
          }
        },
        "additionalProperties": true
      }
    },
    "indicators_h1": { "type": "object" }
  },
  "additionalProperties": true
}
