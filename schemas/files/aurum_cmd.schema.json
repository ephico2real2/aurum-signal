{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signal-system.local/schemas/files/aurum_cmd.schema.json",
  "title": "python/config/aurum_cmd.json",
  "description": "AURUM or ATHENA writes; BRIDGE consumes and deletes. BRIDGE dedupes on timestamp.",
  "oneOf": [
    {
      "type": "object",
      "required": ["action", "new_mode", "timestamp"],
      "properties": {
        "action": { "const": "MODE_CHANGE" },
        "new_mode": {
          "type": "string",
          "enum": ["OFF", "WATCH", "SIGNAL", "SCALPER", "HYBRID", "AUTO_SCALPER"]
        },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["action", "timestamp"],
      "properties": {
        "action": { "const": "CLOSE_ALL" },
        "timestamp": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["action", "sql", "timestamp"],
      "properties": {
        "action": { "const": "SCRIBE_QUERY" },
        "sql": { "type": "string", "minLength": 1 },
        "max_rows": { "type": "integer", "minimum": 1, "maximum": 50000 },
        "busy_timeout_ms": { "type": "integer", "minimum": 0, "maximum": 120000 },
        "timeout_sec": { "type": "integer", "minimum": 1, "maximum": 120 },
        "reply_to": { "type": "string" },
        "timestamp": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["action", "timestamp"],
      "properties": {
        "action": { "const": "SHELL_EXEC" },
        "program": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "type": ["string", "number", "boolean"] }
        },
        "cmd": { "type": "string", "minLength": 1 },
        "timeout_sec": { "type": "integer", "minimum": 1, "maximum": 300 },
        "reply_to": { "type": "string" },
        "timestamp": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["program"] },
        { "required": ["cmd"] }
      ],
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["action", "kind", "timestamp"],
      "properties": {
        "action": { "const": "ANALYSIS_RUN" },
        "kind": { "type": "string", "minLength": 1 },
        "query_id": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "notify": {
          "type": "object",
          "properties": {
            "telegram": { "type": "boolean" },
            "chat_id": { "type": ["string", "integer", "null"] },
            "header": { "type": ["string", "null"] },
            "footer": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "reason": { "type": "string" },
        "reply_to": { "type": "string" },
        "timestamp": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["action", "payload", "timestamp"],
      "properties": {
        "action": { "const": "AURUM_EXEC" },
        "endpoint": { "type": "string" },
        "payload": {
          "type": "object",
          "required": ["action"],
          "properties": {
            "action": { "type": "string", "enum": ["SCRIBE_QUERY", "SHELL_EXEC", "HEALTH_CHECK"] }
          },
          "additionalProperties": true
        },
        "timeout_sec": { "type": "integer", "minimum": 1, "maximum": 120 },
        "reply_to": { "type": "string" },
        "timestamp": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["action", "direction", "sl", "tp1", "timestamp"],
      "properties": {
        "action": { "type": "string", "enum": ["OPEN_GROUP", "OPEN_TRADE"] },
        "direction": { "type": "string", "enum": ["BUY", "SELL", "buy", "sell"] },
        "entry_low": { "type": "number", "exclusiveMinimum": 0 },
        "entry_high": { "type": "number", "exclusiveMinimum": 0 },
        "entry_legs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["entry_price"],
            "properties": {
              "order_type": {
                "type": "string",
                "enum": [
                  "AUTO",
                  "BUY_LIMIT",
                  "SELL_LIMIT",
                  "BUY_STOP",
                  "SELL_STOP",
                  "BUY_STOP_LIMIT",
                  "SELL_STOP_LIMIT",
                  "BUY_STOPLIMIT",
                  "SELL_STOPLIMIT"
                ]
              },
              "entry_price": { "type": "number", "exclusiveMinimum": 0 },
              "stoplimit_price": { "type": "number", "exclusiveMinimum": 0 },
              "tp": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": true
          }
        },
        "sl": { "type": "number", "exclusiveMinimum": 0 },
        "tp1": { "type": "number", "exclusiveMinimum": 0 },
        "tp2": {},
        "tp3": {},
        "lot_per_trade": { "type": "number" },
        "lots": { "type": "number" },
        "entry": {},
        "tp": {},
        "timestamp": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" }
      },
      "anyOf": [
        { "required": ["entry_low"] },
        { "required": ["entry_legs"] }
      ],
      "additionalProperties": true
    }
  ]
}
