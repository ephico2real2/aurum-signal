# ──────────────────────────────────────────────
# SIGNAL SYSTEM — Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── Claude API ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Telegram (Telethon — user account for reading signal channels) ──
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# ── Telegram channels to monitor (comma-separated channel IDs or usernames) ──
# Get channel ID by forwarding a message from the channel to @userinfobot
TELEGRAM_CHANNELS=-1001234567890,-1009876543210

# ── Telegram Bot (for HERALD notifications and AURUM responses) ───
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff
TELEGRAM_CHAT_ID=987654321

# ── MT5 File paths ─────────────────────────────
# macOS MT5 native app Files path:
MT5_FILES_PATH=/Users/YOUR_USERNAME/Library/Application Support/MetaQuotes/Terminal/TERMINAL_ID/MQL5/Files/
# Or use the shared Common/Files path (works across terminals):
# MT5_FILES_PATH=/Users/YOUR_USERNAME/Library/Application Support/MetaQuotes/Terminal/Common/Files/

# These paths must be the SAME folder FORGE.mq5 uses (Terminal → Common → Files).
# Best: symlink repo MT5/ → Common/Files (see SETUP.md). Otherwise use absolute paths below.
MT5_MARKET_FILE=MT5/market_data.json
MT5_CMD_FILE=MT5/command.json
MT5_CONFIG_FILE=MT5/config.json
MT5_MODE_FILE=MT5/mode_status.json
# Example absolute (replace with your Common/Files):
# MT5_CMD_FILE=/Users/YOU/Library/Application Support/MetaQuotes/Terminal/Common/Files/command.json

# ── TradingView MCP (LewisWJackson) ────────────
LENS_MCP_CMD=npx tradingview-mcp-jackson
LENS_SYMBOL=XAUUSD
LENS_EXCHANGE=FX_IDC
LENS_TIMEFRAMES=5m,1h
# In-memory cache; keep ≤ BRIDGE_LENS_SEC unless you know callers need longer TTL
LENS_CACHE_SEC=60
# Refresh TradingView MCP while BRIDGE is in WATCH (seconds; 0 = disable)
LENS_WATCH_REFRESH_SEC=60
LENS_BBW_SQUEEZE=0.035

# ── Trading parameters ─────────────────────────
DEFAULT_MODE=SIGNAL
AEGIS_RISK_PCT=2.0
AEGIS_MAX_RISK_PCT=5.0
AEGIS_NUM_TRADES=8
AEGIS_MAX_SLIPPAGE=20.0
AEGIS_MIN_RR=1.2
AEGIS_MAX_DAILY_LOSS=5.0
AEGIS_MAX_OPEN_GROUPS=3
AEGIS_MAX_LOT_TOTAL=5.0

# ── TP management ──────────────────────────────
TP1_CLOSE_PCT=70
TP2_CLOSE_PCT=20
MOVE_BE_ON_TP1=true

# ── SENTINEL (news guard + RSS) ────────────────
# See docs/SENTINEL.md
SENTINEL_GUARD_MIN=30
SENTINEL_POLL_SEC=60
# Post-event guard windows (minutes after scheduled start time):
#   Instant events (NFP, CPI, etc.): SENTINEL_POST_GUARD_MIN (default 5)
#   Extended events (speeches, FOMC, press conferences): SENTINEL_EXTENDED_GUARD_MIN (default 60)
# SENTINEL_POST_GUARD_MIN=5
# SENTINEL_EXTENDED_GUARD_MIN=60
# ForexFactory calendar: which currency columns count (EU/Asia/US). USD-only: SENTINEL_CALENDAR_CURRENCIES=USD
# SENTINEL_CALENDAR_CURRENCIES=USD,EUR,GBP,JPY,AUD,NZD,CAD,CHF
# Free RSS: FXStreet + Google News (forex/ECB/BOJ/FOMC) + Investing.com forex. Disable: SENTINEL_ENABLE_NEWS_FEEDS=0
# SENTINEL_GOOGLE_NEWS_QUERY=forex OR XAUUSD OR ECB OR BOJ OR AUD OR GBP
# DailyFX often 403 from cloud IPs — default off; try at home: SENTINEL_ENABLE_DAILYFX_RSS=1
# SENTINEL_EXTRA_RSS_URLS=https://example.com/your-free-forex-rss.xml

# ── AURUM (AI agent) ───────────────────────────
AURUM_MODEL=claude-sonnet-4-20250514
AURUM_MAX_TOKENS=1000
SOUL_FILE=SOUL.md
SKILL_FILE=SKILL.md

# ── ATHENA (dashboard) ─────────────────────────
ATHENA_PORT=7842
DASHBOARD_DIR=dashboard
# Optional — only POST /api/scribe/query: set a shared secret to require
#   Authorization: Bearer <secret>  OR  header X-ATHENA-SCRIBE-TOKEN: <secret>
# Leave unset for typical local-only use (no auth on that endpoint).
# ATHENA_SCRIBE_QUERY_SECRET=
# SCRIBE_QUERY_MAX_ROWS=500
# SCRIBE_QUERY_BUSY_MS=5000

# ── SCRIBE (database) ──────────────────────────
SCRIBE_DB=data/aurum_intelligence.db

# ── BRIDGE (orchestrator) ──────────────────────
BRIDGE_LOOP_SEC=5
# How often to call TradingView MCP (each call is heavy); 30–120s typical
BRIDGE_LENS_SEC=60
BRIDGE_SENTINEL_SEC=60
BRIDGE_MT5_STALE=120

# ── AEGIS enhancements ─────────────────────────────────────────────
AEGIS_SESSION_RESET_HOUR=7       # Daily loss reset at 07:00 UTC (London open)
AEGIS_SCALE_DOWN_LOSSES=3        # Reduce lots after N consecutive losses
AEGIS_SCALE_UP_WINS=3            # Increase lots after N consecutive wins
AEGIS_SCALE_DOWN_FACTOR=0.5      # Half lots when scaling down

# ── RECONCILER ─────────────────────────────────────────────────────
RECON_INTERVAL_SEC=3600          # Run reconciliation every hour
RECON_PNL_TOLERANCE=1.0          # Ignore P&L differences below this $

# ── SESSION BOUNDARIES (UTC hours) ─────────────────────────────────
# ASIAN wraps midnight when START > END (e.g. 22–08 UTC = Tokyo/Sydney into London).
# Flat range when START < END (e.g. 1–8 = main Tokyo hours only) — leaves 22–01 as OFF_HOURS.
SESSION_ASIAN_START=22
SESSION_ASIAN_END=8
SESSION_LONDON_START=8
SESSION_LONDON_END=13
SESSION_LONDON_NY_START=13
SESSION_LONDON_NY_END=17
SESSION_NY_START=17
SESSION_NY_END=22

# ── AEGIS trading-day boundary (daily loss limit / session P&L in Python) ──
# If unset, rolls at SESSION_LONDON_START UTC. Override only if you want a different hour.
# AEGIS_SESSION_RESET_HOUR=1

# ── MT5 BROKER INFO ────────────────────────────────────────────────
MT5_BROKER_FILE=MT5/broker_info.json
# Written by FORGE on startup — account type (DEMO/LIVE), broker, server

# ── ATHENA / component heartbeats ───────────────────────────────────
# ATHENA_PORT=7842
# Mirror each heartbeat to Flask (non-blocking) after SQLite write:
# COMPONENT_HEARTBEAT_USE_HTTP=1
# ATHENA_INTERNAL_BASE=http://127.0.0.1:7842
# LISTENER idle grid refresh interval (seconds):
# LISTENER_HEARTBEAT_SEC=120
